---
// src/components/Ruleta.astro
---

<div id="zona-ruleta" class="oculto">
  <div class="ruleta-modal-card">
    <div class="puntero">▼</div>
    <div class="ruleta" id="ruleta">
      <div class="numero-container num-1"><span class="numero">1</span></div>
      <div class="numero-container num-2"><span class="numero">2</span></div>
      <div class="numero-container num-3"><span class="numero">3</span></div>
    </div>
    <button id="btn-girar">¡Girar Ruleta!</button>
    <h3 id="resultado-ruleta"></h3>
  </div>
</div>

<style>
  .oculto {
    display: none !important;
  }

  #zona-ruleta {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    animation: fadeInOverlay 0.3s ease;
  }

  @keyframes fadeInOverlay {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .ruleta-modal-card {
    background: linear-gradient(135deg, rgba(30, 41, 59, 0.9), rgba(15, 23, 42, 0.95));
    border: 2px solid rgba(255, 255, 255, 0.15);
    border-radius: 32px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
    animation: scalePopIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes scalePopIn {
    from { transform: scale(0.85); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .puntero {
    font-size: 2.5rem;
    color: #fb6f92; 
    z-index: 10;
    margin-bottom: -18px;
  }

  .ruleta {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    position: relative;
    overflow: hidden;
    border: 5px solid #fb6f92;
    background: conic-gradient(
      #ffb3c6 0deg 120deg,
      #ff8fab 120deg 240deg,
      #fb6f92 240deg 360deg
    );
    transition: transform 2s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .numero-container {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
  }

  .num-1 { transform: rotate(60deg); }
  .num-2 { transform: rotate(180deg); }
  .num-3 { transform: rotate(300deg); }

  .numero {
    position: absolute;
    top: 15px; 
    left: 50%;
    transform: translateX(-50%);
    font-size: 2.5rem;
    font-weight: bold;
    color: white;
    text-shadow: 1px 1px 3px rgba(0,0,0,0.3);
  }

  #btn-girar {
    margin-top: 20px;
    padding: 12px 30px;
    font-size: 1.3rem;
    cursor: pointer;
    background-color: #fb6f92;
    color: white;
    border: none;
    border-radius: 50px;
    font-weight: bold;
    box-shadow: 0 4px 15px rgba(251, 111, 146, 0.4);
    transition: all 0.2s;
  }

  #btn-girar:hover {
    background-color: #ff8fab;
    transform: translateY(-2px);
  }

  #btn-girar:disabled {
    background-color: #ffc2d1;
    cursor: not-allowed;
    transform: none;
  }

  #resultado-ruleta {
    margin-top: 15px;
    font-size: 1.6rem;
    color: #fde68a;
    font-weight: 800;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }
</style>

<script>
  import { audioController } from '../utils/audioController';

  function iniciarRuleta() {
    const zonaRuleta = document.getElementById('zona-ruleta');
    const ruleta = document.getElementById('ruleta');
    const btnGirar = document.getElementById('btn-girar') as HTMLButtonElement;
    const resultadoTexto = document.getElementById('resultado-ruleta');

    if (!zonaRuleta || !ruleta || !btnGirar || !resultadoTexto) return;

    let rotacionActual = 0;

    document.addEventListener('respuestaCorrecta', () => {
      zonaRuleta.classList.remove('oculto');
      resultadoTexto.innerText = "";
    });

    btnGirar.addEventListener('click', () => {
      btnGirar.disabled = true;
      resultadoTexto.innerText = "¡Girando ruleta...!";

      audioController.play('ruleta', true);

      const numeroGanador = Math.floor(Math.random() * 3) + 1;
      const angulosAjuste = { 1: 300, 2: 180, 3: 60 };
      const gradosFinales = angulosAjuste[numeroGanador as keyof typeof angulosAjuste];
      
      rotacionActual += (360 * 5); 
      const resto = rotacionActual % 360;
      rotacionActual += (gradosFinales - resto);

      ruleta.style.transform = `rotate(${rotacionActual}deg)`;

      setTimeout(() => {
        audioController.stop('ruleta');
        audioController.play('despues_ruleta');
        resultadoTexto.innerText = `¡Avanzas ${numeroGanador} casillas!`;
        
        document.dispatchEvent(new CustomEvent('avanzarFicha', { detail: { pasos: numeroGanador } }));

        setTimeout(() => {
          zonaRuleta.classList.add('oculto');
          btnGirar.disabled = false;
          document.dispatchEvent(new CustomEvent('siguienteTurno'));
        }, 3500);

      }, 2000);
    });
  }

  iniciarRuleta();
</script>