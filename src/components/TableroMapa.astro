---
import '../styles/board.css';
---

<div class="mapa-container">
  <div class="mapa-info">
    <span>🗺️</span> Camino al Éxito
  </div>

  <div id="camino-tablero" class="camino-tablero"></div>

  <div class="leaderboard-section">
    <h3 class="leaderboard-title">📊 Posiciones y Sincronización Física</h3>
    <div id="leaderboard-list" class="leaderboard-list"></div>
  </div>
</div>

<div id="victoria-modal" class="victoria-overlay hidden">
  <div class="victoria-card">
    <div class="victoria-badge">🏆 ¡VICTORIA! 🏆</div>
    <div class="victoria-avatar" id="ganador-avatar">🏆</div>
    <h2 class="victoria-team-name" id="ganador-name">Equipo Ganador</h2>
    <p class="victoria-congrats">
      ¡Han demostrado ser unos increíbles matemáticos y han llegado a la meta final!
    </p>

    <div class="victoria-stats-section">
      <h3>📊 Resumen de la Partida</h3>
      <table class="stats-table">
        <thead>
          <tr>
            <th>Equipo</th>
            <th>Casilla Final</th>
            <th>Aciertos ✅</th>
            <th>Errores ❌</th>
          </tr>
        </thead>
        <tbody id="victoria-stats-tbody"></tbody>
      </table>
    </div>

    <button id="btn-jugar-nuevo" class="btn-play-again">Jugar de Nuevo 🎮</button>
  </div>
</div>

<script>
  import confetti from "canvas-confetti";
  import { audioController } from "../utils/audioController";

  let totalCasillas = 100;
  let posicionesEquipos: Record<string, number> = {};

  function inicializarTablero() {
    const saved = localStorage.getItem("serpientes_escaleras_setup");
    const contenedor = document.getElementById("camino-tablero");
    if (!contenedor) return;

    const savedPosiciones = localStorage.getItem("serpientes_escaleras_posiciones");
    if (savedPosiciones) {
      try {
        posicionesEquipos = JSON.parse(savedPosiciones);
      } catch (e) {
        console.error("Error al cargar posiciones persistidas:", e);
      }
    }

    if (saved) {
      const parsed = JSON.parse(saved);
      if (parsed.boardTiles) totalCasillas = parsed.boardTiles;

      if (parsed.teams && Array.isArray(parsed.teams)) {
        parsed.teams.forEach((team: any) => {
          if (posicionesEquipos[team.name] === undefined) {
            posicionesEquipos[team.name] = 0;
          }
        });
      }
    }

    contenedor.innerHTML = "";
    for (let i = 0; i <= totalCasillas; i++) {
      const nodo = document.createElement("div");
      const isInicio = i === 0;
      const isMeta = i === totalCasillas;

      let extraClass = "";
      if (isMeta) extraClass = "meta";
      else if (isInicio) extraClass = "inicio";

      nodo.className = `casilla-nodo ${extraClass}`;
      nodo.id = `casilla-${i}`;
      
      if (isInicio) {
        nodo.innerText = "🚀 Inicio";
      } else if (isMeta) {
        nodo.innerText = `🏁 Meta (${i})`;
      } else {
        nodo.innerText = i.toString();
      }
      contenedor.appendChild(nodo);
    }

    localStorage.setItem("serpientes_escaleras_posiciones", JSON.stringify(posicionesEquipos));

    actualizarFichasVisuales();
    actualizarTablaPosiciones();
  }

  function actualizarFichasVisuales() {
    document.querySelectorAll(".ficha-jugador").forEach((f) => f.remove());
    document.querySelectorAll(".contenedor-fichas-casilla").forEach((c) => c.remove());
    document.querySelectorAll(".casilla-nodo").forEach((c) => c.classList.remove("ocupada"));

    Object.entries(posicionesEquipos).forEach(([equipoName, casillaActual]) => {
      const casillaNodo = document.getElementById(`casilla-${casillaActual}`);

      if (casillaNodo) {
        casillaNodo.classList.add("ocupada");

        let contenedorFichas = casillaNodo.querySelector(".contenedor-fichas-casilla");
        if (!contenedorFichas) {
          contenedorFichas = document.createElement("div");
          contenedorFichas.className = "contenedor-fichas-casilla";
          casillaNodo.appendChild(contenedorFichas);
        }

        const saved = localStorage.getItem("serpientes_escaleras_setup");
        let avatar = "🦁";
        if (saved) {
          const parsed = JSON.parse(saved);
          const t = parsed.teams.find((team: any) => team.name === equipoName);
          if (t) avatar = t.avatar;
        }

        const ficha = document.createElement("span");
        ficha.className = "ficha-jugador";
        ficha.innerText = avatar;
        ficha.title = equipoName;

        contenedorFichas.appendChild(ficha);
      }
    });
  }

  function actualizarTablaPosiciones() {
    const listContenedor = document.getElementById("leaderboard-list");
    if (!listContenedor) return;

    const saved = localStorage.getItem("serpientes_escaleras_setup");
    if (!saved) return;

    try {
      const parsed = JSON.parse(saved);
      if (!parsed.teams || !Array.isArray(parsed.teams)) return;

      const equiposOrdenados = [...parsed.teams].sort((a: any, b: any) => {
        const posA = posicionesEquipos[a.name] !== undefined ? posicionesEquipos[a.name] : 0;
        const posB = posicionesEquipos[b.name] !== undefined ? posicionesEquipos[b.name] : 0;
        return posB - posA;
      });

      listContenedor.innerHTML = "";

      const rankEmojis = ['🥇', '🥈', '🥉', '🎖️'];

      equiposOrdenados.forEach((team: any, index: number) => {
        const currentPos = posicionesEquipos[team.name] !== undefined ? posicionesEquipos[team.name] : 0;
        const posTexto = currentPos === 0 ? "Inicio" : `Casilla ${currentPos} / ${totalCasillas}`;
        const rankBadge = rankEmojis[index] || `${index + 1}º`;

        const item = document.createElement("div");
        item.className = "leaderboard-item";
        item.style.borderLeft = `5px solid ${team.hexColor}`;

        item.innerHTML = `
          <div class="leaderboard-team-info">
            <span class="badge-casilla" style="font-size: 1.1rem;">${rankBadge}</span>
            <span class="leaderboard-avatar">${team.avatar}</span>
            <span class="leaderboard-team-name" style="color: ${team.hexColor}">${team.name}</span>
          </div>
          <div class="leaderboard-stats">
            <span class="badge-casilla">${posTexto}</span>
            <button class="btn-adj btn-menos" data-team="${team.name}">-</button>
            <button class="btn-adj btn-mas" data-team="${team.name}">+</button>
          </div>
        `;
        listContenedor.appendChild(item);
      });

      listContenedor.querySelectorAll(".btn-menos").forEach((btn) => {
        btn.addEventListener("click", (e: any) => {
          const teamName = e.target.getAttribute("data-team");
          ajustarPosicionManual(teamName, -1);
        });
      });

      listContenedor.querySelectorAll(".btn-mas").forEach((btn) => {
        btn.addEventListener("click", (e: any) => {
          const teamName = e.target.getAttribute("data-team");
          ajustarPosicionManual(teamName, 1);
        });
      });
    } catch (e) {
      console.error("Error al actualizar la tabla de posiciones:", e);
    }
  }

  function ajustarPosicionManual(equipoName: string, cambio: number) {
    const posActual = posicionesEquipos[equipoName] !== undefined ? posicionesEquipos[equipoName] : 0;
    let nuevaPosicion = posActual + cambio;

    if (nuevaPosicion < 0) nuevaPosicion = 0;
    if (nuevaPosicion > totalCasillas) nuevaPosicion = totalCasillas;

    posicionesEquipos[equipoName] = nuevaPosicion;
    localStorage.setItem("serpientes_escaleras_posiciones", JSON.stringify(posicionesEquipos));

    actualizarFichasVisuales();
    actualizarTablaPosiciones();

    const nodoDestino = document.getElementById(`casilla-${nuevaPosicion}`);
    if (nodoDestino) {
      nodoDestino.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }

    if (nuevaPosicion === totalCasillas) {
      document.dispatchEvent(new CustomEvent("juegoConcluido", { detail: { ganador: equipoName } }));
    }
  }

  function mostrarVictoria(ganadorName: string) {
    const modal = document.getElementById("victoria-modal");
    const avatarEl = document.getElementById("ganador-avatar");
    const nameEl = document.getElementById("ganador-name");
    const tbody = document.getElementById("victoria-stats-tbody");
    if (!modal || !avatarEl || !nameEl || !tbody) return;

    const saved = localStorage.getItem("serpientes_escaleras_setup");
    if (!saved) return;

    try {
      const parsed = JSON.parse(saved);
      const equipos = parsed.teams || [];

      const ganador = equipos.find((t: any) => t.name === ganadorName);
      avatarEl.textContent = ganador ? ganador.avatar : "🏆";
      nameEl.textContent = ganadorName;
      if (ganador) {
        nameEl.style.color = ganador.hexColor;
      }

      audioController.play("victoria");

      const duration = 7 * 1000;
      const end = Date.now() + duration;

      (function frame() {
        confetti({ particleCount: 6, angle: 60, spread: 60, origin: { x: 0, y: 0.7 } });
        confetti({ particleCount: 6, angle: 120, spread: 60, origin: { x: 1, y: 0.7 } });

        if (Date.now() < end) {
          requestAnimationFrame(frame);
        }
      })();

      tbody.innerHTML = "";
      equipos.forEach((t: any) => {
        const finalPos = posicionesEquipos[t.name] !== undefined ? posicionesEquipos[t.name] : 0;
        const correct = t.correctAnswers || 0;
        const incorrect = t.incorrectAnswers || 0;
        const posTexto = finalPos === 0 ? "Inicio" : `Casilla ${finalPos}`;

        const row = document.createElement("tr");
        row.innerHTML = `
          <td>
            <div class="leaderboard-team-info">
              <span>${t.avatar}</span>
              <span style="color: ${t.hexColor}">${t.name}</span>
            </div>
          </td>
          <td>${posTexto}</td>
          <td style="color: #22c55e; font-weight: bold;">${correct}</td>
          <td style="color: #ef4444; font-weight: bold;">${incorrect}</td>
        `;
        tbody.appendChild(row);
      });

      modal.classList.remove("hidden");
    } catch (e) {
      console.error("Error al mostrar pantalla de victoria:", e);
    }
  }

  document.addEventListener("renderizarMovimientoTablero", (e: any) => {
    const { equipoName, pasos } = e.detail;

    if (posicionesEquipos[equipoName] === undefined) {
      posicionesEquipos[equipoName] = 0;
    }

    let nuevaPosicion = posicionesEquipos[equipoName] + pasos;
    let llegoAMeta = false;

    if (nuevaPosicion >= totalCasillas) {
      nuevaPosicion = totalCasillas;
      llegoAMeta = true;
      const info = document.getElementById("info-turno");
      if (info) info.innerHTML = `🎉 ¡El <strong>${equipoName}</strong> ha ganado el juego! 🏆`;
    } else if (nuevaPosicion < 0) {
      nuevaPosicion = 0;
    }

    posicionesEquipos[equipoName] = nuevaPosicion;
    localStorage.setItem("serpientes_escaleras_posiciones", JSON.stringify(posicionesEquipos));

    actualizarFichasVisuales();
    actualizarTablaPosiciones();

    if (llegoAMeta) {
      document.dispatchEvent(new CustomEvent("juegoConcluido", { detail: { ganador: equipoName } }));
    }

    const nodoDestino = document.getElementById(`casilla-${nuevaPosicion}`);
    if (nodoDestino) {
      nodoDestino.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }
  });

  document.addEventListener("juegoConcluido", (e: any) => {
    mostrarVictoria(e.detail.ganador);
  });

  document.addEventListener("DOMContentLoaded", () => {
    const btnJugarNuevo = document.getElementById("btn-jugar-nuevo");
    if (btnJugarNuevo) {
      btnJugarNuevo.addEventListener("click", () => {
        posicionesEquipos = {};
        localStorage.removeItem("serpientes_escaleras_posiciones");

        const saved = localStorage.getItem("serpientes_escaleras_setup");
        if (saved) {
          try {
            const parsed = JSON.parse(saved);
            if (parsed.teams && Array.isArray(parsed.teams)) {
              parsed.teams = parsed.teams.map((t: any) => ({
                ...t,
                correctAnswers: 0,
                incorrectAnswers: 0,
              }));
              localStorage.setItem("serpientes_escaleras_setup", JSON.stringify(parsed));
            }
          } catch (e) {
            console.error("Error al limpiar estadísticas:", e);
          }
        }

        const modal = document.getElementById("victoria-modal");
        if (modal) modal.classList.add("hidden");

        window.location.href = "/Setup";
      });
    }
  });

  inicializarTablero();
  document.addEventListener("DOMContentLoaded", inicializarTablero);
  document.addEventListener("astro:page-load", inicializarTablero);

  document.addEventListener("setupActualizado", () => {
    posicionesEquipos = {};
    inicializarTablero();
  });
</script>
