---
// src/components/TableroMapa.astro
---

<div class="mapa-container">
  <div class="mapa-info">
    <span id="info-turno">🗺️ Camino al Éxito</span>
  </div>

  <div id="camino-tablero" class="camino-tablero"></div>

  <!-- Tabla de Posiciones en Tiempo Real -->
  <div class="leaderboard-section">
    <h3 class="leaderboard-title">📊 Posiciones y Sincronización Física</h3>
    <div id="leaderboard-list" class="leaderboard-list">
      <!-- Se inyecta con JavaScript -->
    </div>
  </div>
</div>

<!-- Modal de Fin de Juego (Victoria) -->
<div id="victoria-modal" class="victoria-overlay hidden">
  <div class="victoria-card">
    <div class="victoria-badge">🏆 ¡VICTORIA! 🏆</div>
    <div class="victoria-avatar" id="ganador-avatar">🏆</div>
    <h2 class="victoria-team-name" id="ganador-name">Equipo Ganador</h2>
    <p class="victoria-congrats">
      ¡Han demostrado ser unos increíbles matemáticos y han llegado a la meta
      final!
    </p>

    <div class="victoria-stats-section">
      <h3>📊 Resumen de la Partida</h3>
      <table class="stats-table">
        <thead>
          <tr>
            <th>Equipo</th>
            <th>Casilla Final</th>
            <th>Aciertos ✅</th>
            <th>Errores ❌</th>
          </tr>
        </thead>
        <tbody id="victoria-stats-tbody">
          <!-- Se inyecta con JavaScript -->
        </tbody>
      </table>
    </div>

    <button id="btn-jugar-nuevo" class="btn-play-again"
      >Jugar de Nuevo 🎮</button
    >
  </div>
</div>

<style>
  .mapa-container {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    border: 2px solid rgba(255, 255, 255, 0.15);
    padding: 20px;
    border-radius: 24px;
    margin: 1.5rem 0;
    width: 90%;
    max-width: 850px;
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
  }

  .mapa-info {
    text-align: center;
    font-size: 1.3rem;
    font-weight: bold;
    color: #ffffff;
    margin-bottom: 1.2rem;
    text-shadow: 0 2px 8px rgba(255, 255, 255, 0.3);
  }

  .camino-tablero {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    max-height: 220px;
    overflow-y: auto;
    padding: 10px;
    background: rgba(0, 0, 0, 0.4);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Scrollbar personalizado para que no se vea el feo del sistema */
  .camino-tablero::-webkit-scrollbar {
    width: 6px;
  }
  .camino-tablero::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
  }

  /* Estilo base de cada casilla (Optimizado para albergar fichas en su base) */
  :global(.casilla-nodo) {
    width: 55px;
    height: 55px;
    background: rgba(255, 255, 255, 0.1);
    border: 2px solid #c084fc;
    color: #ffffff;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    position: relative;
    box-shadow: 0 0 10px rgba(192, 132, 252, 0.2);
  }

  /* Casilla Meta */
  :global(.casilla-nodo.meta) {
    background: linear-gradient(135deg, #10b981, #059669);
    border-color: #34d399;
    color: white;
    border-radius: 12px;
    width: auto;
    padding: 0 15px;
    box-shadow: 0 0 15px rgba(16, 185, 129, 0.5);
  }

  /* Contenedor flexible de fichas que evita que se encimen dentro de una casilla */
  :global(.contenedor-fichas-casilla) {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    justify-content: center;
    align-items: center;
    position: absolute;
    bottom: -6px;
    width: 100%;
    pointer-events: none;
  }

  /* Jugadores dentro de la casilla (Estilizados sin absolute) */
  :global(.ficha-jugador) {
    font-size: 1.15rem;
    z-index: 10;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.6);
    animation: brincar 0.5s infinite alternate;
  }

  @keyframes brincar {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-4px);
    }
  }

  /* Estilos de la tabla de posiciones */
  .leaderboard-section {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    width: 100%;
    text-align: left;
  }

  .leaderboard-title {
    font-size: 1.25rem;
    color: #ffffff;
    margin-top: 0;
    margin-bottom: 1rem;
    font-weight: 700;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .leaderboard-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  :global(.leaderboard-item) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(15, 23, 42, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 0.8rem 1.2rem;
    transition: all 0.25s ease;
  }

  :global(.leaderboard-item:hover) {
    background: rgba(15, 23, 42, 0.65);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }

  :global(.leaderboard-team-info) {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  :global(.leaderboard-avatar) {
    font-size: 1.8rem;
    background: rgba(255, 255, 255, 0.08);
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    box-shadow: inset 0 1px 2px rgba(255, 255, 255, 0.1);
  }

  :global(.leaderboard-name) {
    font-weight: bold;
    font-size: 1.1rem;
  }

  :global(.leaderboard-pos) {
    color: #a5f3fc;
    font-weight: 600;
    font-size: 0.95rem;
    background: rgba(165, 243, 252, 0.1);
    padding: 2px 10px;
    border-radius: 12px;
    border: 1px solid rgba(165, 243, 252, 0.2);
  }

  :global(.leaderboard-controls) {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  :global(.btn-adj) {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #ffffff;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    font-size: 1.25rem;
    font-weight: 800;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  :global(.btn-adj:hover) {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.5);
    transform: scale(1.1);
  }

  :global(.btn-adj:active) {
    transform: scale(0.9);
  }

  /* Estilos del Modal de Victoria */
  .victoria-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    transition: opacity 0.4s ease;
  }

  .victoria-overlay.hidden {
    display: none;
  }

  .victoria-card {
    background: linear-gradient(
      135deg,
      rgba(30, 41, 59, 0.9),
      rgba(15, 23, 42, 0.95)
    );
    border: 2px solid rgba(255, 255, 255, 0.15);
    border-radius: 32px;
    padding: 3rem 2.5rem;
    width: 90%;
    max-width: 550px;
    text-align: center;
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.6);
    position: relative;
    animation: modalPopIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    overflow: hidden;
  }

  @keyframes modalPopIn {
    0% {
      transform: scale(0.85);
      opacity: 0;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .victoria-badge {
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    color: #1e1b4b;
    padding: 0.5rem 1.8rem;
    border-radius: 50px;
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 2px;
    display: inline-block;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 15px rgba(245, 158, 11, 0.4);
  }

  .victoria-avatar {
    font-size: 4.5rem;
    margin-bottom: 1rem;
    animation: pulseAvatar 1.5s infinite alternate;
  }

  @keyframes pulseAvatar {
    0% {
      transform: scale(1);
      filter: drop-shadow(0 0 10px rgba(250, 204, 21, 0.2));
    }
    100% {
      transform: scale(1.1);
      filter: drop-shadow(0 0 25px rgba(250, 204, 21, 0.6));
    }
  }

  .victoria-team-name {
    font-size: 2.5rem;
    font-weight: 800;
    margin-top: 0;
    margin-bottom: 1rem;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .victoria-congrats {
    color: #e2e8f0;
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .victoria-stats-section {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    text-align: left;
  }

  .victoria-stats-section h3 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.15rem;
    color: #cbd5e1;
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 0.5rem;
  }

  .stats-table {
    width: 100%;
    border-collapse: collapse;
  }

  .stats-table th,
  .stats-table td {
    padding: 8px 12px;
    text-align: center;
  }

  .stats-table th {
    color: #94a3b8;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .stats-table td {
    color: #f1f5f9;
    font-size: 1rem;
  }

  .stats-table tr:not(:last-child) {
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  :global(.stats-team-cell) {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: bold;
  }

  .btn-play-again {
    background: linear-gradient(135deg, #10b981, #059669);
    border: none;
    color: #ffffff;
    font-size: 1.2rem;
    font-weight: 800;
    padding: 1rem 3rem;
    border-radius: 50px;
    cursor: pointer;
    box-shadow: 0 10px 25px rgba(16, 185, 129, 0.3);
    transition: all 0.3s ease;
  }

  .btn-play-again:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 15px 35px rgba(16, 185, 129, 0.5);
  }

  .btn-play-again:active {
    transform: translateY(-1px) scale(0.98);
  }
</style>

<script>
  import confetti from "canvas-confetti";
  import { audioController } from "../utils/audioController";

  let totalCasillas = 100;
  let posicionesEquipos: Record<string, number> = {};

  function inicializarTablero() {
    const saved = localStorage.getItem("serpientes_escaleras_setup");
    const contenedor = document.getElementById("camino-tablero");
    if (!contenedor) return;

    // Cargar posiciones persistidas si existen
    const savedPosiciones = localStorage.getItem(
      "serpientes_escaleras_posiciones",
    );
    if (savedPosiciones) {
      try {
        posicionesEquipos = JSON.parse(savedPosiciones);
      } catch (e) {
        console.error("Error al cargar posiciones persistidas:", e);
      }
    }

    if (saved) {
      const parsed = JSON.parse(saved);
      if (parsed.boardTiles) totalCasillas = parsed.boardTiles;

      if (parsed.teams && Array.isArray(parsed.teams)) {
        parsed.teams.forEach((team: any) => {
          if (posicionesEquipos[team.name] === undefined) {
            posicionesEquipos[team.name] = 1;
          }
        });
      }
    }

    contenedor.innerHTML = "";
    for (let i = 1; i <= totalCasillas; i++) {
      const nodo = document.createElement("div");
      nodo.className = `casilla-nodo ${i === totalCasillas ? "meta" : ""}`;
      nodo.id = `casilla-${i}`;
      nodo.innerText = i === totalCasillas ? `🏁 Meta (${i})` : i.toString();
      contenedor.appendChild(nodo);
    }

    // Persistir las posiciones actuales iniciales
    localStorage.setItem(
      "serpientes_escaleras_posiciones",
      JSON.stringify(posicionesEquipos),
    );

    actualizarFichasVisuales();
    actualizarTablaPosiciones();
  }

  function actualizarFichasVisuales() {
    // 1. Limpiamos las fichas existentes y contenedores previos para reconstruir de forma limpia
    document.querySelectorAll(".ficha-jugador").forEach((f) => f.remove());
    document
      .querySelectorAll(".contenedor-fichas-casilla")
      .forEach((c) => c.remove());

    Object.entries(posicionesEquipos).forEach(([equipoName, casillaActual]) => {
      const casillaNodo = document.getElementById(`casilla-${casillaActual}`);

      if (casillaNodo) {
        // 2. Creamos o recuperamos el contenedor flexible de fichas interno de la casilla
        let contenedorFichas = casillaNodo.querySelector(
          ".contenedor-fichas-casilla",
        );
        if (!contenedorFichas) {
          contenedorFichas = document.createElement("div");
          contenedorFichas.className = "contenedor-fichas-casilla";
          casillaNodo.appendChild(contenedorFichas);
        }

        const saved = localStorage.getItem("serpientes_escaleras_setup");
        let avatar = "🦁";
        if (saved) {
          const parsed = JSON.parse(saved);
          const t = parsed.teams.find((team: any) => team.name === equipoName);
          if (t) avatar = t.avatar;
        }

        const ficha = document.createElement("span");
        ficha.className = "ficha-jugador";
        ficha.innerText = avatar;
        ficha.title = equipoName;

        // 3. Añadimos la ficha dentro del contenedor para que flexbox la acomode automáticamente sin encimarse
        contenedorFichas.appendChild(ficha);
      }
    });
  }

  function actualizarTablaPosiciones() {
    const listContenedor = document.getElementById("leaderboard-list");
    if (!listContenedor) return;

    const saved = localStorage.getItem("serpientes_escaleras_setup");
    if (!saved) return;

    try {
      const parsed = JSON.parse(saved);
      if (!parsed.teams || !Array.isArray(parsed.teams)) return;

      // Obtener equipos ordenados de mayor a menor según su posición
      const equiposOrdenados = [...parsed.teams].sort((a: any, b: any) => {
        const posA = posicionesEquipos[a.name] || 1;
        const posB = posicionesEquipos[b.name] || 1;
        return posB - posA;
      });

      listContenedor.innerHTML = "";

      equiposOrdenados.forEach((team: any, index: number) => {
        const currentPos = posicionesEquipos[team.name] || 1;

        const item = document.createElement("div");
        item.className = "leaderboard-item";

        item.innerHTML = `
          <div class="leaderboard-team-info">
            <span class="leaderboard-pos">${index + 1}º</span>
            <span class="leaderboard-avatar">${team.avatar}</span>
            <span class="leaderboard-name" style="color: ${team.hexColor}">${team.name}</span>
          </div>
          <div class="leaderboard-controls">
            <span class="leaderboard-pos">Casilla ${currentPos} / ${totalCasillas}</span>
            <button class="btn-adj btn-menos" data-team="${team.name}">-</button>
            <button class="btn-adj btn-mas" data-team="${team.name}">+</button>
          </div>
        `;
        listContenedor.appendChild(item);
      });

      // Agregar listeners a los botones de ajuste manual
      listContenedor.querySelectorAll(".btn-menos").forEach((btn) => {
        btn.addEventListener("click", (e: any) => {
          const teamName = e.target.getAttribute("data-team");
          ajustarPosicionManual(teamName, -1);
        });
      });

      listContenedor.querySelectorAll(".btn-mas").forEach((btn) => {
        btn.addEventListener("click", (e: any) => {
          const teamName = e.target.getAttribute("data-team");
          ajustarPosicionManual(teamName, 1);
        });
      });
    } catch (e) {
      console.error("Error al actualizar la tabla de posiciones:", e);
    }
  }

  function ajustarPosicionManual(equipoName: string, cambio: number) {
    const posActual = posicionesEquipos[equipoName] || 1;
    let nuevaPosicion = posActual + cambio;

    if (nuevaPosicion < 1) nuevaPosicion = 1;
    if (nuevaPosicion > totalCasillas) nuevaPosicion = totalCasillas;

    posicionesEquipos[equipoName] = nuevaPosicion;
    localStorage.setItem(
      "serpientes_escaleras_posiciones",
      JSON.stringify(posicionesEquipos),
    );

    actualizarFichasVisuales();
    actualizarTablaPosiciones();

    // Centrar vista en la casilla a la que se movió
    const nodoDestino = document.getElementById(`casilla-${nuevaPosicion}`);
    if (nodoDestino) {
      nodoDestino.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }

    // Verificar si alcanzó la victoria mediante el ajuste manual
    if (nuevaPosicion === totalCasillas) {
      document.dispatchEvent(
        new CustomEvent("juegoConcluido", { detail: { ganador: equipoName } }),
      );
    }
  }

  function mostrarVictoria(ganadorName: string) {
    const modal = document.getElementById("victoria-modal");
    const avatarEl = document.getElementById("ganador-avatar");
    const nameEl = document.getElementById("ganador-name");
    const tbody = document.getElementById("victoria-stats-tbody");
    if (!modal || !avatarEl || !nameEl || !tbody) return;

    const saved = localStorage.getItem("serpientes_escaleras_setup");
    if (!saved) return;

    try {
      const parsed = JSON.parse(saved);
      const equipos = parsed.teams || [];

      // Encontrar avatar del ganador
      const ganador = equipos.find((t: any) => t.name === ganadorName);
      avatarEl.textContent = ganador ? ganador.avatar : "🏆";
      nameEl.textContent = ganadorName;
      if (ganador) {
        nameEl.style.color = ganador.hexColor;
      }

      // Reproducir sonido de victoria
      audioController.play("victoria");

      // Tirar confeti continuo (fuegos artificiales)
      const duration = 7 * 1000;
      const end = Date.now() + duration;

      (function frame() {
        confetti({
          particleCount: 6,
          angle: 60,
          spread: 60,
          origin: { x: 0, y: 0.7 },
        });
        confetti({
          particleCount: 6,
          angle: 120,
          spread: 60,
          origin: { x: 1, y: 0.7 },
        });

        if (Date.now() < end) {
          requestAnimationFrame(frame);
        }
      })();

      // Llenar tabla de estadísticas
      tbody.innerHTML = "";
      equipos.forEach((t: any) => {
        const finalPos = posicionesEquipos[t.name] || 1;
        const correct = t.correctAnswers || 0;
        const incorrect = t.incorrectAnswers || 0;

        const row = document.createElement("tr");
        row.innerHTML = `
          <td>
            <div class="stats-team-cell">
              <span>${t.avatar}</span>
              <span style="color: ${t.hexColor}">${t.name}</span>
            </div>
          </td>
          <td>Casilla ${finalPos}</td>
          <td style="color: #22c55e; font-weight: bold;">${correct}</td>
          <td style="color: #ef4444; font-weight: bold;">${incorrect}</td>
        `;
        tbody.appendChild(row);
      });

      // Mostrar modal
      modal.classList.remove("hidden");
    } catch (e) {
      console.error("Error al mostrar pantalla de victoria:", e);
    }
  }

  // ESCUCHAR MOVIMIENTOS
  document.addEventListener("renderizarMovimientoTablero", (e: any) => {
    const { equipoName, pasos } = e.detail;

    if (posicionesEquipos[equipoName] === undefined) {
      posicionesEquipos[equipoName] = 1;
    }

    // Calcular la nueva posición sumando o restando los pasos
    let nuevaPosicion = posicionesEquipos[equipoName] + pasos;
    let llegoAMeta = false;

    // 🛡️ CONTROL DE LÍMITES SUPERIOR E INFERIOR
    if (nuevaPosicion >= totalCasillas) {
      nuevaPosicion = totalCasillas;
      llegoAMeta = true;
      const info = document.getElementById("info-turno");
      if (info)
        info.innerHTML = `🎉 ¡El <strong>${equipoName}</strong> ha ganado el juego! 🏆`;
    } else if (nuevaPosicion < 1) {
      // Evita ir a casillas negativas o cero, devolviendo al jugador a la casilla de salida (1)
      nuevaPosicion = 1;
    }

    // Actualizamos la posición real del equipo y persistimos
    posicionesEquipos[equipoName] = nuevaPosicion;
    localStorage.setItem(
      "serpientes_escaleras_posiciones",
      JSON.stringify(posicionesEquipos),
    );

    actualizarFichasVisuales();
    actualizarTablaPosiciones();

    // 🏆 SOLO SE LANZA EL EVENTO CONCLUIDO SI SE ALCANZA LA CASILLA META
    if (llegoAMeta) {
      document.dispatchEvent(
        new CustomEvent("juegoConcluido", { detail: { ganador: equipoName } }),
      );
    }

    const nodoDestino = document.getElementById(`casilla-${nuevaPosicion}`);
    if (nodoDestino) {
      nodoDestino.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }
  });

  // Escuchar fin del juego para mostrar victoria
  document.addEventListener("juegoConcluido", (e: any) => {
    mostrarVictoria(e.detail.ganador);
  });

  // Botón Jugar de nuevo
  document.addEventListener("DOMContentLoaded", () => {
    const btnJugarNuevo = document.getElementById("btn-jugar-nuevo");
    if (btnJugarNuevo) {
      btnJugarNuevo.addEventListener("click", () => {
        // 1. Restablecer posiciones a 1
        posicionesEquipos = {};
        localStorage.removeItem("serpientes_escaleras_posiciones");

        // 2. Limpiar estadísticas en localStorage
        const saved = localStorage.getItem("serpientes_escaleras_setup");
        if (saved) {
          try {
            const parsed = JSON.parse(saved);
            if (parsed.teams && Array.isArray(parsed.teams)) {
              parsed.teams = parsed.teams.map((t: any) => ({
                ...t,
                correctAnswers: 0,
                incorrectAnswers: 0,
              }));
              localStorage.setItem(
                "serpientes_escaleras_setup",
                JSON.stringify(parsed),
              );
            }
          } catch (e) {
            console.error("Error al limpiar estadísticas:", e);
          }
        }

        // 3. Ocultar modal e ir a la página de setup
        const modal = document.getElementById("victoria-modal");
        if (modal) modal.classList.add("hidden");

        // Redirigir a Setup
        window.location.href = "/Setup";
      });
    }
  });

  // Forzar inicialización en cualquier ciclo de vida de Astro
  inicializarTablero();
  document.addEventListener("DOMContentLoaded", inicializarTablero);
  document.addEventListener("astro:page-load", inicializarTablero);

  document.addEventListener("setupActualizado", () => {
    posicionesEquipos = {};
    inicializarTablero();
  });
</script>
