---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-content">
    <p class="utvam-text">
      Desarrollado por Ingeniería en Desarrollo y Gestión de Software
    </p>
    <p class="utvam-title">
      <strong>UTVAM</strong>
    </p>
    <p class="sub-text">
      Universidad Tecnológica de la Zona Metropolitana del Valle de México &copy; {currentYear}
    </p>
  </div>
</footer>

<style>
  .footer {
    background: rgba(15, 23, 42, 0.24);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    color: #e0e7ff;
    padding: 2.5rem 1rem;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    margin-top: auto;
    position: relative;
    z-index: 1;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 -10px 30px rgba(15, 23, 42, 0.18);
  }


  .footer-content {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .utvam-text {
    font-size: 1rem;
    margin: 0;
    background: linear-gradient(90deg,  #FF6B6B, #CC5DE8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: none;
    filter: drop-shadow(0 0 8px rgba(255, 146, 43, 0.25));
  }

  .utvam-title {
    font-size: 1.6rem;
    margin: 5px 0;
    letter-spacing: 3px;
  }

  .utvam-title strong {
    background: linear-gradient(90deg, #FFE066, #FF922B, #FF6B6B, #CC5DE8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: none;
    filter: drop-shadow(0 0 8px rgba(255, 146, 43, 0.4));
  }

  .sub-text {
    font-size: 0.85rem;
    margin: 0;
    background: linear-gradient(90deg, #FF6B6B, #CC5DE8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: none;
    filter: drop-shadow(0 0 6px rgba(255, 146, 43, 0.2));
  }
</style>
