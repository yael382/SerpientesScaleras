---
const { showLevelButtons = false } = Astro.props;
---

<nav class="navbar">
  <div class="nav-container">
    <a href="/" class="logo">
      <span class="logo-text">Serpientes y Escaleras</span>
    </a>

    {showLevelButtons ? (
      <div class="nav-links">
        <a href="/Alpha" class="link alfa">Nivel Alfa</a>
        <a href="/Beta" class="link beta">Nivel Beta</a>
      </div>
    ) : null}
  </div>
</nav>

<style>
  .navbar {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.14), inset 0 1px 2px rgba(255, 255, 255, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.35);
    padding: 1.2rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom-left-radius: 24px;
    border-bottom-right-radius: 24px;
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    flex-shrink: 0;
  }

  .logo:hover {
    transform: scale(1.08);
    filter: drop-shadow(0 4px 12px rgba(124, 58, 237, 0.3));
  }

  .logo-text {
    color: #1F1035;
    font-weight: 900;
    text-shadow: 2px 2px 4px rgba(255, 255, 255, 0.6), 0 0 20px rgba(124, 58, 237, 0.2);
    letter-spacing: 0.5px;
  }

  @media (max-width: 600px) {
    .nav-container {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
