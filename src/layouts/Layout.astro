---
import Navbar from '../components/navbar.astro';
import Footer from '../components/footer.astro';
import '../styles/global.css';
import '../styles/setup.css';
import '../styles/game.css';
import '../styles/board.css';

interface Props {
  isHome?: boolean;
  showLevelButtons?: boolean;
}

const { isHome = false, showLevelButtons = false } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Serpientes y Escaleras - UTVAM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
  </head>
  <body class={isHome ? 'home' : ''}>
    <div class="math-rain" aria-hidden="true"></div>

    <Navbar showLevelButtons={showLevelButtons} />

    <main class="container">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  html, body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: url('/1.png') center/cover no-repeat fixed;
    background-attachment: fixed;
    overflow-x: hidden;
  }

  .container {
    flex: 1;
    width: 100%;
    max-width: 1100px;
    margin: 2rem auto;
    padding: 0 1rem;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }

  .math-rain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .math-rain span {
    position: absolute;
    top: -10%;
    font-size: 1.4rem;
    font-weight: 700;
    opacity: 0;
    white-space: nowrap;
    animation: rainFall var(--duration) linear infinite, sway var(--sway) ease-in-out infinite alternate;
    filter: drop-shadow(0 0 6px rgba(0,0,0,0.18));
  }

  @keyframes rainFall {
    0% { top: -10%; opacity: 0; }
    10% { opacity: 1; }
    100% { top: 120vh; opacity: 0.2; }
  }

  @keyframes sway {
    0% { transform: translateX(0); }
    100% { transform: translateX(var(--drift)); }
  }
</style>
