---
import Layout from '../layouts/Layout.astro';
import TableroMapa from '../components/TableroMapa.astro';
import Ruleta from '../components/Ruleta.astro'; // 1. IMPORTAMOS LA RULETA
import RuletaRetroceso from '../components/RuletaRetroceso.astro'; // 1. IMPORTAMOS LA RULETA DE RETROCESO
import ModalAlpha from '../components/ModalAlpha.astro';// 2. IMPORTAMOS EL MODAL DE REGLAS
---

<Layout showLevelButtons={true}>
  <ModalAlpha />
  <div class="game-container">
    <h1 class="level-title">Nivel Alfa</h1>

    <div id="turn-indicator" class="turn-indicator hidden">
      <div class="turn-avatar" id="turn-avatar">🦁</div>
      <div class="turn-info">
        <div class="turn-team" id="turn-team">Cargando equipo...</div>
        <div class="turn-member">Turno de: <strong id="turn-member">...</strong></div>
      </div>
    </div>

    <div class="screen">
      <h2 id="math-question">Cargando...</h2>
    </div>

    <div id="timer-box" class="timer-box hidden">
      <span class="timer-icon">⏱️</span>
      <span id="time-left">60</span>s
    </div>

    <div class="fruits-container" id="options-container"></div>

    <p id="feedback-message" class="feedback"></p>

    <Ruleta />
    <TableroMapa />

    <RuletaRetroceso />
  </div>
</Layout>

<style is:global>
  .game-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-top: 2rem;
    animation: fadeInUp 0.6s ease-out;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .level-title {
    font-size: 2.2rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: #f8fafc;
    font-weight: 800;
    text-shadow: 2px 2px 10px rgba(15, 23, 42, 0.2);
    filter: drop-shadow(1px 1px 4px rgba(15, 23, 42, 0.15));
  }

  .turn-indicator {
    display: flex;
    align-items: center;
    gap: 15px;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(10px);
    border: 2px solid rgba(255, 255, 255, 0.2);
    padding: 10px 20px;
    border-radius: 20px;
    margin-bottom: 1.5rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    transition: all 0.3s ease;
  }
  .turn-indicator.hidden { display: none; }
  .turn-avatar {
    font-size: 2.5rem;
    background: rgba(255, 255, 255, 0.1);
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
  }
  .turn-info {
    text-align: left;
  }
  .turn-team {
    font-size: 1.2rem;
    font-weight: 800;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-shadow: 1px 1px 4px rgba(0,0,0,0.6);
  }
  .turn-member {
    font-size: 1.1rem;
    color: #e2e8f0;
    margin-top: 2px;
  }
  .turn-member strong {
    color: #fbbf24;
    font-size: 1.3rem;
  }

  .screen {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.45), rgba(30, 41, 59, 0.25));
    backdrop-filter: blur(25px) saturate(180%);
    -webkit-backdrop-filter: blur(25px) saturate(180%);
    color: #ffffff;
    padding: 2.5rem 3rem;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background-clip: padding-box;
    box-shadow: 
      0 24px 60px rgba(0, 0, 0, 0.4), 
      inset 0 1px 1px rgba(255, 255, 255, 0.12),
      inset 0 -1px 2px rgba(255, 255, 255, 0.05),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    margin-bottom: 2.5rem;
    width: 100%;
    max-width: 680px;
    position: relative;
    z-index: 1;
  }

  #math-question {
    font-size: 4rem;
    margin: 0;
    font-family: 'Fredoka', monospace;
    letter-spacing: 5px;
    color: #ffffff;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .challenge-card {
    text-align: left;
    animation: fadeSlideIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(12px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)   scale(1);    }
  }

  .challenge-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }

  .challenge-icon {
    font-size: 2rem;
    line-height: 1;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.4));
  }

  .challenge-badge {
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 50px;
    padding: 0.2rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #e0e7ff;
    backdrop-filter: blur(8px);
  }

  .challenge-body {
    font-size: 1.25rem;
    line-height: 1.7;
    color: #f1f5f9;
    margin: 0;
    font-weight: 500;
    letter-spacing: 0.2px;
  }

  .challenge-body strong {
    color: #fbbf24;
    font-weight: 800;
  }

  .challenge-body em {
    display: block;
    margin-top: 0.6rem;
    color: #a5f3fc;
    font-style: normal;
    font-weight: 700;
    font-size: 1.15rem;
  }

  .frac {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    vertical-align: middle;
    margin: 0 0.35em;
    line-height: 1;
    font-size: 1em;
  }
  .frac-num {
    font-size: 0.9em;
    font-weight: 900;
    color: #fde68a;
    line-height: 1.2;
    padding: 0 0.2em 0.05em;
    border-bottom: 2.5px solid #fbbf24;
    min-width: 1em;
    text-align: center;
    letter-spacing: 0;
  }
  .frac-den {
    font-size: 0.9em;
    font-weight: 900;
    color: #fde68a;
    line-height: 1.2;
    padding: 0.05em 0.2em 0;
    min-width: 1em;
    text-align: center;
    letter-spacing: 0;
  }

  .fruits-container {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
  }

  .fruit-btn {
    border-radius: 24px;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    min-width: 220px;
    font-size: 2.1rem;
    font-weight: 800;
    padding: 1.6rem 2.4rem;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.3);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #ffffff !important;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
  }

  .fruit-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: all 0.6s ease;
    transform: skewX(-25deg);
  }

  .fruit-btn:hover::before {
    left: 150%;
  }

  .fruit-btn:hover {
    transform: translateY(-8px) scale(1.03);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.2);
  }

  .fruit-btn.blue-card {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.5), rgba(59, 130, 246, 0.2));
    border: 1px solid rgba(59, 130, 246, 0.5);
  }

  .fruit-btn.green-card {
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.5), rgba(16, 185, 129, 0.2));
    border: 1px solid rgba(16, 185, 129, 0.5);
  }

  .fruit-btn.red-card {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.5), rgba(239, 68, 68, 0.2));
    border: 1px solid rgba(239, 68, 68, 0.5);
  }

  .fruit-btn.yellow-card {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.55), rgba(245, 158, 11, 0.25));
    border: 1px solid rgba(245, 158, 11, 0.5);
  }

  .fruit-btn:active {
    transform: translateY(-2px) scale(0.98);
  }

  .timer-box {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 50px;
    padding: 0.45rem 1.2rem;
    font-size: 1.4rem;
    font-weight: 800;
    color: #a5f3fc;
    backdrop-filter: blur(12px);
    margin-bottom: 1rem;
    transition: color 0.3s, border-color 0.3s;
  }
  .timer-box.timer-warning {
    color: #f87171;
    border-color: rgba(248, 113, 113, 0.5);
    animation: timerPulse 0.8s ease-in-out infinite;
  }
  @keyframes timerPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
  .timer-icon { font-size: 1.1rem; }

  .feedback {
    font-size: 1.5rem;
    font-weight: bold;
    margin-top: 2rem;
    min-height: 2rem;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  }

  .correct {
    color: #22c55e;
    animation: correctPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .incorrect {
    color: #ef4444;
    animation: shake 0.5s ease;
  }

  @keyframes correctPop {
    0% { transform: scale(0.5); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-10px); }
    75% { transform: translateX(10px); }
  }

  @media (max-width: 600px) {
    .level-title { font-size: 1.8rem; margin-bottom: 1rem; }
    .screen { padding: 1.5rem 1rem; border-radius: 20px; margin-bottom: 1.5rem; min-width: 0; width: 100%; box-sizing: border-box; }
    #math-question { font-size: 2.5rem; letter-spacing: 2px; }
    .fruits-container { gap: 1rem; width: 100%; }
    :global(.fruit-btn) { min-width: 0; width: 100%; box-sizing: border-box; font-size: 1.4rem; padding: 1.1rem 1.5rem; border-radius: 16px; }
  }

  @media (max-width: 360px) {
    #math-question { font-size: 2rem; }
    :global(.fruit-btn) { font-size: 1.2rem; }
  }
</style>

<script>
  import confetti from 'canvas-confetti';
  import { turnManager } from '../lib/turnManager';
  import { ChallengePool } from '../utils/fracGeo';
  import { generateMathQuestion } from '../utils/mathgenerator';

  const challengePool = new ChallengePool('5to', 2);

  const questionEl = document.getElementById('math-question');
  const optionsContainer = document.getElementById('options-container');
  const feedbackEl = document.getElementById('feedback-message');

  let isAnswering = false;
  let challengeTimer: ReturnType<typeof setInterval> | undefined;
  const timerBox = document.getElementById('timer-box');
  const timeLeftEl = document.getElementById('time-left');

  function startChallengeTimer(duration: number) {
    clearInterval(challengeTimer);
    let timeLeft = duration;
    if (timeLeftEl) timeLeftEl.textContent = String(timeLeft);
    if (timerBox) { timerBox.classList.remove('hidden', 'timer-warning'); }

    challengeTimer = setInterval(() => {
      timeLeft--;
      if (timeLeftEl) timeLeftEl.textContent = String(timeLeft);
      if (timeLeft <= 10 && timerBox) timerBox.classList.add('timer-warning');
      if (timeLeft <= 0) {
        clearInterval(challengeTimer);
        handleChallengeTimeout();
      }
    }, 1000);
  }

  function stopChallengeTimer() {
    clearInterval(challengeTimer);
    if (timerBox) timerBox.classList.add('hidden');
  }

  function handleChallengeTimeout() {
    if (isAnswering) return;
    isAnswering = true;
    if (feedbackEl) {
      feedbackEl.textContent = '⏰ ¡Tiempo agotado!';
      feedbackEl.style.color = '#f87171';
    }
    document.querySelectorAll<HTMLButtonElement>('#options-container .fruit-btn')
      .forEach(btn => { btn.disabled = true; btn.style.opacity = '0.5'; });
    setTimeout(() => {
      try {
        turnManager.comenzarTurno();
        turnManager.resolverTurno({ fueCorrecto: false });
      } catch(e) { console.error(e); }
      if (feedbackEl) { feedbackEl.textContent = ''; feedbackEl.style.color = ''; }
      
      // En vez de pasar pregunta directo, dejamos que la ruleta haga lo suyo si aplica
      document.dispatchEvent(new CustomEvent('abrirRuletaRetroceso'));
    }, 2000);
  }

  try {
    turnManager.inicializar();
    updateTurnUI();
  } catch (e) {
    console.warn("Faltan datos de configuración, redirigiendo a Setup...");
    window.location.href = '/Setup';
  }

  function updateTurnUI() {
    try {
      const turnInfo = turnManager.obtenerTurnoActual();
      const indicator = document.getElementById('turn-indicator');
      const avatarEl = document.getElementById('turn-avatar');
      const teamEl = document.getElementById('turn-team');
      const memberEl = document.getElementById('turn-member');

      if (indicator && avatarEl && teamEl && memberEl) {
        indicator.classList.remove('hidden');
        avatarEl.textContent = turnInfo.equipo.avatar;
        teamEl.textContent = turnInfo.equipo.name;
        teamEl.style.color = turnInfo.equipo.hexColor;
        memberEl.textContent = turnInfo.miembro;
        indicator.style.borderColor = turnInfo.equipo.hexColor;
        indicator.style.boxShadow = `0 8px 32px ${turnInfo.equipo.hexColor}40`;
      }
    } catch (e) {
      console.error("Error al actualizar UI de turno:", e);
    }
  }

  function generateQuestion() {
    isAnswering = false;
    if (feedbackEl) feedbackEl.textContent = "";

    const useChallenge = Math.random() > 0.5;

    if (useChallenge) {
      const challenge = challengePool.next();
      if (questionEl) {
        questionEl.innerHTML = challenge.htmlQuestion;
        questionEl.style.fontSize = '';
        questionEl.style.letterSpacing = '';
      }
      startChallengeTimer(challenge.timeLimit);
      renderOptions(challenge.options);
    } else {
      const question = generateMathQuestion('Alpha');
      if (questionEl) {
        questionEl.textContent = question.text;
        questionEl.style.fontSize = '4rem';
        questionEl.style.letterSpacing = '5px';
      }
      stopChallengeTimer();
      renderOptions(question.options);
    }
  }

  function renderOptions(options: { value: number; isCorrect: boolean }[]) {
    if (!optionsContainer) return;
    optionsContainer.innerHTML = '';

    const labels = ['A', 'B'];
    const colorClasses = ['blue-card', 'green-card', 'red-card', 'yellow-card'];

    options.forEach((opt, index) => {
      const btn = document.createElement('button');
      btn.className = `fruit-btn ${colorClasses[index % colorClasses.length]}`;
      btn.textContent = `Opción ${labels[index]}: ${opt.value}`;

      btn.addEventListener('click', () => {
        if (!isAnswering) checkAnswer(opt.isCorrect);
      });

      optionsContainer.appendChild(btn);
    });
  }

  function checkAnswer(isCorrect: boolean) {
    if (!feedbackEl || !optionsContainer || isAnswering) return;
    isAnswering = true;
    stopChallengeTimer();

    try {
      turnManager.comenzarTurno();
      turnManager.resolverTurno({ fueCorrecto: isCorrect });
    } catch(e) { console.error(e) }

    if (isCorrect) {
      feedbackEl.textContent = "¡Correcto!";
      feedbackEl.className = "feedback correct";

      const audioGanar = new Audio('/sounds/Ganar.mp3');
      audioGanar.play();

      confetti({ particleCount: 250, spread: 180, origin: { y: 0.6 } });

      optionsContainer.style.display = 'none'; 
      document.dispatchEvent(new CustomEvent('respuestaCorrecta'));

    } else {
      feedbackEl.textContent = "Intenta de nuevo";
      feedbackEl.className = "feedback incorrect";

      const audioPerder = new Audio('/sounds/perder.mp3');
      audioPerder.play();

      if (optionsContainer) optionsContainer.style.display = 'none';

      // Disparamos la ruleta inmediatamente
      document.dispatchEvent(new CustomEvent('abrirRuletaRetroceso'));

      for (let i = 0; i < 25; i++) {
        const x = document.createElement('div');
        x.textContent = '❌'; 
        x.style.position = 'fixed';
        x.style.top = '-60px';
        x.style.left = Math.random() * 100 + 'vw'; 
        x.style.fontSize = Math.random() * (65 - 40) + 40 + 'px';
        x.style.zIndex = '9999';
        x.style.pointerEvents = 'none';
        x.style.transition = 'transform 2.5s cubic-bezier(0.25, 1, 0.5, 1), opacity 2.5s ease';
        
        document.body.appendChild(x);

        setTimeout(() => {
          x.style.transform = `translateY(115vh) rotate(${Math.random() * 720 - 360}deg)`;
          x.style.opacity = '0';
          setTimeout(() => x.remove(), 2500);
        }, Math.random() * 600);
      }
      
      // ¡ELIMINADO EL SETTIMEOUT VIEJO AQUÍ! Ahora el cambio de turno lo maneja la ruleta al terminar.
    }
  }

  // Se activa cuando la ruleta de retroceso termina de girar
  document.addEventListener('retrocesoCompletado', (e: any) => {
    const casillasARetar = e.detail.casillas;
    console.log(`⚠️ Ruleta del destino: El jugador debe retroceder ${casillasARetar} espacios.`);
    
    // Cambiamos el turno y generamos la siguiente pregunta justo después de que la ruleta termina
    try {
      turnManager.siguienteTurno();
      updateTurnUI();
    } catch(e) { console.error(e) }

    if (feedbackEl) feedbackEl.textContent = "";
    if (optionsContainer) optionsContainer.style.display = 'flex'; 
    generateQuestion();
  });

  // Escuchar cuando la ruleta de avance normal termine su turno
  document.addEventListener('siguienteTurno', () => {
    try {
      turnManager.siguienteTurno();
      updateTurnUI();
    } catch(e) { console.error(e) }

    if (feedbackEl) feedbackEl.textContent = "";
    if (optionsContainer) optionsContainer.style.display = 'flex'; 
    generateQuestion();
  });

 // 5. ACTUALIZADO: Enviar el movimiento detallado hacia el TableroMapa
  document.addEventListener('avanzarFicha', (e: any) => {
    const pasos = e.detail.pasos;
    
    try {
      const datosTurno = turnManager.obtenerTurnoActual();
      const equipoActivo = datosTurno.equipo;
    
      document.dispatchEvent(new CustomEvent('renderizarMovimientoTablero', {
        detail: {
          equipoName: equipoActivo.name,
          equipoAvatar: equipoActivo.avatar,
          pasos: pasos
        }
      }));
    } catch (err) {
      console.error("Error enviando datos del turno al tablero:", err);
    }
  });

  generateQuestion();
</script>