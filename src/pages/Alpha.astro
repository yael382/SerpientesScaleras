---
import Layout from '../layouts/Layout.astro';
import Ruleta from '../components/Ruleta.astro'; // 1. IMPORTAMOS LA RULETA
---

<Layout showLevelButtons={true}>
  <div id="rules-modal" class="modal-overlay">
    <div class="modal-card animate-pop">
      <div class="modal-header">
        <span class="modal-icon">🦆</span>
        <h2>¡Bienvenidos al Nivel Alfa!</h2>
      </div>
      <div class="modal-body">
        <p class="modal-subtitle">Sigue estas reglas para ganar la carrera:</p>
        <ul class="rules-list">
          <li><span>✌️</span> Resuelve la suma o resta mágica correctamente para desbloquear la ruleta.</li>
          <li><span>🎯</span> Presiona el botón central para girar la ruleta y descubrir cuántos pasos avanzas.</li>
          <li><span>🚀</span> ¡Salta de oca en oca y vuela directo a la meta antes que los demás!</li>
        </ul>
      </div>
      <button type="button" id="btn-close-rules" class="modal-btn">
        ¡Entendido, a Jugar! 🎲
      </button>
    </div>
  </div>

  <div class="game-container">
    <h1 class="level-title">Nivel Alfa</h1>

    <div id="turn-indicator" class="turn-indicator hidden">
      <div class="turn-avatar" id="turn-avatar">🦁</div>
      <div class="turn-info">
        <div class="turn-team" id="turn-team">Cargando equipo...</div>
        <div class="turn-member">Turno de: <strong id="turn-member">...</strong></div>
      </div>
    </div>

    <div class="screen">
      <h2 id="math-question">Cargando...</h2>
    </div>

    <div class="fruits-container" id="options-container"></div>

    <p id="feedback-message" class="feedback"></p>

    <Ruleta />
  </div>
</Layout>

<style>
  /* --- NUEVOS ESTILOS DEL MODAL ANIMADO DE REGLAS --- */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(15, 12, 38, 0.85);
    backdrop-filter: blur(8px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 10000; /* Siempre por encima del juego y ruletas */
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .modal-card {
    background: #ffffff;
    width: 90%;
    max-width: 500px;
    padding: 2.5rem;
    border-radius: 32px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    text-align: center;
    box-sizing: border-box;
    border: 3px solid #FF922B; /* Borde naranja del modo Alfa */
  }

  .modal-header {
    margin-bottom: 1.5rem;
  }

  .modal-icon {
    font-size: 3.5rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .modal-card h2 {
    font-size: 2rem;
    color: #1e1b4b;
    margin: 0;
    font-family: 'Fredoka', sans-serif;
  }

  .modal-subtitle {
    font-size: 1.1rem;
    color: #64748b;
    margin-bottom: 1.5rem;
  }

  .rules-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
    text-align: left;
  }

  .rules-list li {
    font-size: 1.05rem;
    color: #334155;
    margin-bottom: 1.2rem;
    display: flex;
    gap: 0.75rem;
    line-height: 1.4;
  }

  .modal-btn {
    background: linear-gradient(135deg, #ff922b 0%, #f57c00 100%);
    color: white;
    border: none;
    padding: 1rem 2.5rem;
    font-size: 1.2rem;
    font-weight: bold;
    border-radius: 999px;
    cursor: pointer;
    box-shadow: 0 8px 20px rgba(245, 124, 0, 0.4);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .modal-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 25px rgba(245, 124, 0, 0.5);
  }

  /* Animaciones del Modal */
  .animate-pop {
    animation: popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .modal-fade-out {
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  @keyframes popIn {
    0% { transform: scale(0.7); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  /* --- TU CSS ORIGINAL (SIN MODIFICACIONES) --- */
<style is:global>
  /* ... Tu CSS original se mantiene exactamente igual ... */
  .game-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-top: 2rem;
    animation: fadeInUp 0.6s ease-out;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .level-title {
    font-size: 2.2rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: #f8fafc;
    font-weight: 800;
    text-shadow: 2px 2px 10px rgba(15, 23, 42, 0.2);
    filter: drop-shadow(1px 1px 4px rgba(15, 23, 42, 0.15));
  }

  .turn-indicator {
    display: flex;
    align-items: center;
    gap: 15px;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(10px);
    border: 2px solid rgba(255, 255, 255, 0.2);
    padding: 10px 20px;
    border-radius: 20px;
    margin-bottom: 1.5rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    transition: all 0.3s ease;
  }
  .turn-indicator.hidden { display: none; }
  .turn-avatar {
    font-size: 2.5rem;
    background: rgba(255, 255, 255, 0.1);
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
  }
  .turn-info {
    text-align: left;
  }
  .turn-team {
    font-size: 1.2rem;
    font-weight: 800;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-shadow: 1px 1px 4px rgba(0,0,0,0.6);
  }
  .turn-member {
    font-size: 1.1rem;
    color: #e2e8f0;
    margin-top: 2px;
  }
  .turn-member strong {
    color: #fbbf24;
    font-size: 1.3rem;
  }

  .screen {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.45), rgba(30, 41, 59, 0.25));
    backdrop-filter: blur(25px) saturate(180%);
    -webkit-backdrop-filter: blur(25px) saturate(180%);
    color: #ffffff;
    padding: 2.5rem 5rem;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background-clip: padding-box;
    box-shadow: 
      0 24px 60px rgba(0, 0, 0, 0.4), 
      inset 0 1px 1px rgba(255, 255, 255, 0.12),
      inset 0 -1px 2px rgba(255, 255, 255, 0.05),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    margin-bottom: 2.5rem;
    min-width: 360px;
    position: relative;
    z-index: 1;
  }

  #math-question {
    font-size: 4rem;
    margin: 0;
    font-family: 'Fredoka', monospace;
    letter-spacing: 5px;
    color: #ffffff;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .fruits-container {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
  }

  .fruit-btn {
    border-radius: 24px;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    min-width: 220px;
    font-size: 2.1rem;
    font-weight: 800;
    padding: 1.6rem 2.4rem;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.3);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #ffffff !important;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
  }

  .fruit-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.3),
      transparent
    );
    transition: all 0.6s ease;
    transform: skewX(-25deg);
  }

  .fruit-btn:hover::before {
    left: 150%;
  }

  .fruit-btn:hover {
    transform: translateY(-8px) scale(1.03);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.2);
  }

  .fruit-btn.blue-card {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.5), rgba(59, 130, 246, 0.2));
    border: 1px solid rgba(59, 130, 246, 0.5);
  }

  .fruit-btn.green-card {
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.5), rgba(16, 185, 129, 0.2));
    border: 1px solid rgba(16, 185, 129, 0.5);
  }

  .fruit-btn.red-card {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.5), rgba(239, 68, 68, 0.2));
    border: 1px solid rgba(239, 68, 68, 0.5);
  }

  .fruit-btn.yellow-card {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.55), rgba(245, 158, 11, 0.25));
    border: 1px solid rgba(245, 158, 11, 0.5);
  }

  .fruit-btn:active {
    transform: translateY(-2px) scale(0.98);
  }

  .feedback {
    font-size: 1.5rem;
    font-weight: bold;
    margin-top: 2rem;
    min-height: 2rem;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  }

  .correct {
    color: #22c55e;
    animation: correctPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .incorrect {
    color: #ef4444;
    animation: shake 0.5s ease;
  }

  @keyframes correctPop {
    0% { transform: scale(0.5); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-10px); }
    75% { transform: translateX(10px); }
  }

  @media (max-width: 600px) {
    .level-title {
      font-size: 1.8rem;
      margin-bottom: 1rem;
    }

    .screen {
      padding: 1.5rem 1rem;
      border-radius: 20px;
      margin-bottom: 1.5rem;
      min-width: 0;
      width: 100%;
      box-sizing: border-box;
    }

    #math-question {
      font-size: 2.5rem;
      letter-spacing: 2px;
    }

    .fruits-container {
      gap: 1rem;
      width: 100%;
    }

    :global(.fruit-btn) {
      min-width: 0;
      width: 100%;
      box-sizing: border-box;
      font-size: 1.4rem;
      padding: 1.1rem 1.5rem;
      border-radius: 16px;
    }
  }

  @media (max-width: 360px) {
    #math-question {
      font-size: 2rem;
    }
    :global(.fruit-btn) {
      font-size: 1.2rem;
    }
  }
</style>
</style>

<script>
  import confetti from 'canvas-confetti';
  import { turnManager } from '../lib/turnManager';
  import { generateMathQuestion } from '../utils/mathGenerator';

  // --- CONTROL DEL MODAL DE REGLAS (NUEVO) ---
  const rulesModal = document.getElementById('rules-modal');
  const btnCloseRules = document.getElementById('btn-close-rules');

  if (btnCloseRules && rulesModal) {
    btnCloseRules.addEventListener('click', () => {
      rulesModal.classList.add('modal-fade-out'); // Inicia animación de desvanecimiento
      setTimeout(() => {
        rulesModal.style.display = 'none'; // Lo quita de pantalla por completo
      }, 400);
    });
  }

  // --- TU LÓGICA ORIGINAL DEL JUEGO ---
  const questionEl = document.getElementById('math-question');
  const optionsContainer = document.getElementById('options-container');
  const feedbackEl = document.getElementById('feedback-message');

  // Inicializar TurnManager y UI
  try {
    turnManager.inicializar();
    updateTurnUI();
  } catch (e) {
    console.warn("Faltan datos de configuración, redirigiendo a Setup...");
    window.location.href = '/Setup';
  }

  function updateTurnUI() {
    try {
      const turnInfo = turnManager.obtenerTurnoActual();
      const indicator = document.getElementById('turn-indicator');
      const avatarEl = document.getElementById('turn-avatar');
      const teamEl = document.getElementById('turn-team');
      const memberEl = document.getElementById('turn-member');

      if (indicator && avatarEl && teamEl && memberEl) {
        indicator.classList.remove('hidden');
        avatarEl.textContent = turnInfo.equipo.avatar;
        teamEl.textContent = turnInfo.equipo.name;
        teamEl.style.color = turnInfo.equipo.hexColor;
        memberEl.textContent = turnInfo.miembro;
        indicator.style.borderColor = turnInfo.equipo.hexColor;
        indicator.style.boxShadow = `0 8px 32px ${turnInfo.equipo.hexColor}40`;
      }
    } catch (e) {
      console.error("Error al actualizar UI de turno:", e);
    }
  }

  function generateQuestion() {
    const question = generateMathQuestion('Alpha');
    
    if (questionEl) {
      questionEl.textContent = question.text;
    }

    renderOptions(question.options);
  }

  function renderOptions(options: { value: number; isCorrect: boolean }[]) {
    if (!optionsContainer) return;
    optionsContainer.innerHTML = '';

    const labels = ['A', 'B'];
    const colorClasses = ['blue-card', 'green-card', 'red-card', 'yellow-card'];

    options.forEach((opt, index) => {
      const btn = document.createElement('button');
      btn.className = `fruit-btn ${colorClasses[index % colorClasses.length]}`;
      btn.textContent = `Opción ${labels[index]}: ${opt.value}`;

      btn.addEventListener('click', () => {
        checkAnswer(opt.isCorrect);
      });

      optionsContainer.appendChild(btn);
    });
  }

  function checkAnswer(isCorrect: boolean) {
    if (!feedbackEl || !optionsContainer) return;

    try {
      turnManager.comenzarTurno();
      turnManager.resolverTurno({ fueCorrecto: isCorrect });
    } catch(e) { console.error(e) }

    if (isCorrect) {
      feedbackEl.textContent = "¡Correcto!";
      feedbackEl.className = "feedback correct";

      const audioGanar = new Audio('/sounds/Ganar.mp3');
      audioGanar.play();

      confetti({
        particleCount: 250,
        spread: 180,
        origin: { y: 0.6 }
      });

      optionsContainer.style.display = 'none'; 
      document.dispatchEvent(new CustomEvent('respuestaCorrecta'));

    } else {
      feedbackEl.textContent = "Intenta de nuevo";
      feedbackEl.className = "feedback incorrect";

      const audioPerder = new Audio('/sounds/perder.mp3');
      audioPerder.play();

      for (let i = 0; i < 25; i++) {
        const x = document.createElement('div');
        x.textContent = '❌'; 
        x.style.position = 'fixed';
        x.style.top = '-60px';
        x.style.left = Math.random() * 100 + 'vw'; 
        x.style.fontSize = Math.random() * (65 - 40) + 40 + 'px';
        x.style.zIndex = '9999';
        x.style.pointerEvents = 'none';
        x.style.transition = 'transform 2.5s cubic-bezier(0.25, 1, 0.5, 1), opacity 2.5s ease';
        
        document.body.appendChild(x);

        setTimeout(() => {
          x.style.transform = `translateY(115vh) rotate(${Math.random() * 720 - 360}deg)`;
          x.style.opacity = '0';
          setTimeout(() => x.remove(), 2500);
        }, Math.random() * 600);
      }

      // Pasar turno automáticamente si se equivoca
      setTimeout(() => {
        try {
          turnManager.siguienteTurno();
          updateTurnUI();
        } catch(e) { console.error(e) }
        generateQuestion();
      }, 1500);
    }
  }

  document.addEventListener('siguienteTurno', () => {
    try {
      turnManager.siguienteTurno();
      updateTurnUI();
    } catch(e) { console.error(e) }

    if (feedbackEl) feedbackEl.textContent = "";
    if (optionsContainer) optionsContainer.style.display = 'flex'; 
    generateQuestion();
  });

  document.addEventListener('avanzarFicha', (e: any) => {
    console.log(`Mover la ficha del jugador: ${e.detail.pasos} espacios.`);
  });

  generateQuestion();
</script>