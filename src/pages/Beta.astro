---
import Layout from '../layouts/Layout.astro';
import Ruleta from '../components/Ruleta.astro'; // 1. IMPORTAMOS LA RULETA EN BETA
---

<Layout showLevelButtons={true}>
  <!-- MODAL DE BIENVENIDA Y REGLAS - MODO BETA (NUEVO) -->
  <div id="rules-modal" class="modal-overlay">
    <div class="modal-card animate-pop">
      <div class="modal-header">
        <span class="modal-icon">🚀</span>
        <h2>¡Bienvenidos al Nivel Beta!</h2>
      </div>
      <div class="modal-body">
        <p class="modal-subtitle">¡La dificultad aumenta en el espacio! Sigue las reglas:</p>
        <ul class="rules-list">
          <li><span>⚡</span> Tienes solo 15 segundos para resolver operaciones de multiplicación y división.</li>
          <li><span>🎯</span> Si respondes bien, desbloquearás la ruleta espacial para avanzar.</li>
          <li><span>🛸</span> Si el tiempo se agota o fallas, el turno pasará al siguiente equipo automáticamente. ¡Sé veloz!</li>
        </ul>
      </div>
      <button type="button" id="btn-close-rules" class="modal-btn">
        ¡Iniciar Misión! 🎲
      </button>
    </div>
  </div>

  <!-- CONTENEDOR PRINCIPAL -->
  <div class="game-container">
    <div class="header-beta">
      <h1 class="level-title">Nivel Beta</h1>
      <div class="timer-box">
        <span id="time-left">15</span>s
      </div>
    </div>

    <div id="turn-indicator" class="turn-indicator hidden">
      <div class="turn-avatar" id="turn-avatar">🦁</div>
      <div class="turn-info">
        <div class="turn-team" id="turn-team">Cargando equipo...</div>
        <div class="turn-member">Turno de: <strong id="turn-member">...</strong></div>
      </div>
    </div>

    <div class="screen">
      <h2 id="math-question">Cargando...</h2>
    </div>

    <div class="fruits-container" id="options-container"></div>

    <p id="feedback-message" class="feedback"></p>

    <Ruleta />
  </div>
</Layout>

<style>
  /* --- NUEVOS ESTILOS DEL MODAL ANIMADO EN MODO BETA --- */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(10, 15, 30, 0.9); /* Un tono más oscuro y espacial */
    backdrop-filter: blur(8px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 10000;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .modal-card {
    background: #ffffff;
    width: 90%;
    max-width: 500px;
    padding: 2.5rem;
    border-radius: 32px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
    text-align: center;
    box-sizing: border-box;
    border: 3px solid #3B82F6; /* Borde Azul característico de Beta */
  }

  .modal-header {
    margin-bottom: 1.5rem;
  }

  .modal-icon {
    font-size: 3.5rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .modal-card h2 {
    font-size: 2rem;
    color: #1e3a5f;
    margin: 0;
    font-family: 'Fredoka', sans-serif;
  }

  .modal-subtitle {
    font-size: 1.1rem;
    color: #64748b;
    margin-bottom: 1.5rem;
  }

  .rules-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
    text-align: left;
  }

  .rules-list li {
    font-size: 1.05rem;
    color: #334155;
    margin-bottom: 1.2rem;
    display: flex;
    gap: 0.75rem;
    line-height: 1.4;
  }

  .modal-btn {
    background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); /* Degradado Azul */
    color: white;
    border: none;
    padding: 1rem 2.5rem;
    font-size: 1.2rem;
    font-weight: bold;
    border-radius: 999px;
    cursor: pointer;
    box-shadow: 0 8px 20px rgba(29, 78, 216, 0.4);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .modal-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 25px rgba(29, 78, 216, 0.5);
  }

  /* Animaciones */
  .animate-pop {
    animation: popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .modal-fade-out {
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  @keyframes popIn {
    0% { transform: scale(0.7); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  /* --- TU CSS ORIGINAL (SE MANTIENE INTEGRO) --- */
<style is:global>
  /* ... Todo tu CSS original se mantiene exactamente igual ... */
  .game-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-top: 2rem;
    animation: fadeInUp 0.6s ease-out;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .header-beta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: 600px;
    margin-bottom: 1.5rem;
  }

  .level-title {
    font-size: 2.2rem;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: #f8fafc;
    font-weight: 800;
    text-shadow: 2px 2px 10px rgba(15, 23, 42, 0.18);
    filter: drop-shadow(1px 1px 4px rgba(15, 23, 42, 0.12));
  }

  .turn-indicator {
    display: flex;
    align-items: center;
    gap: 15px;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(10px);
    border: 2px solid rgba(255, 255, 255, 0.2);
    padding: 10px 20px;
    border-radius: 20px;
    margin-bottom: 1.5rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    transition: all 0.3s ease;
  }
  .turn-indicator.hidden { display: none; }
  .turn-avatar {
    font-size: 2.5rem;
    background: rgba(255, 255, 255, 0.1);
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
  }
  .turn-info {
    text-align: left;
  }
  .turn-team {
    font-size: 1.2rem;
    font-weight: 800;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-shadow: 1px 1px 4px rgba(0,0,0,0.6);
  }
  .turn-member {
    font-size: 1.1rem;
    color: #e2e8f0;
    margin-top: 2px;
  }
  .turn-member strong {
    color: #fbbf24;
    font-size: 1.3rem;
  }

  .timer-box {
    background: linear-gradient(135deg, #EF4444, #F97316);
    color: #fff;
    padding: 0.6rem 1.2rem;
    border-radius: 16px;
    font-size: 1.3rem;
    font-weight: 700;
    font-family: 'Fredoka', monospace;
    box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4);
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: transform 0.2s ease;
  }

  :global(.timer-warning) {
    animation: timerPulse 0.5s ease-in-out infinite;
    background: linear-gradient(135deg, #DC2626, #EF4444) !important;
  }

  @keyframes timerPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }

  .screen {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.45), rgba(30, 41, 59, 0.25));
    backdrop-filter: blur(25px) saturate(180%);
    -webkit-backdrop-filter: blur(25px) saturate(180%);
    color: #ffffff;
    padding: 2.5rem 3rem;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background-clip: padding-box;
    box-shadow: 
      0 24px 60px rgba(0, 0, 0, 0.4), 
      inset 0 1px 1px rgba(255, 255, 255, 0.12),
      inset 0 -1px 2px rgba(255, 255, 255, 0.05),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    margin-bottom: 2.5rem;
    width: 100%;
    max-width: 680px;
    position: relative;
    z-index: 1;
  }

  #math-question {
    font-size: 4rem;
    margin: 0;
    font-family: 'Fredoka', monospace;
    letter-spacing: 5px;
    color: #ffffff;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  /* ── Challenge card styles (fracciones / geometría) ── */
  .challenge-card {
    text-align: left;
    animation: fadeSlideIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(12px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)   scale(1);    }
  }

  .challenge-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }

  .challenge-icon {
    font-size: 2rem;
    line-height: 1;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.4));
  }

  .challenge-badge {
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 50px;
    padding: 0.2rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #e0e7ff;
    backdrop-filter: blur(8px);
  }

  .challenge-body {
    font-size: 1.25rem;
    line-height: 1.7;
    color: #f1f5f9;
    margin: 0;
    font-weight: 500;
    letter-spacing: 0.2px;
  }

  .challenge-body strong {
    color: #fbbf24;
    font-weight: 800;
  }

  .challenge-body em {
    display: block;
    margin-top: 0.6rem;
    color: #a5f3fc;
    font-style: normal;
    font-weight: 700;
    font-size: 1.15rem;
  }

  /* ── Fracción matemática apilada ── */
  .frac {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    vertical-align: middle;
    margin: 0 0.35em;
    line-height: 1;
    font-size: 1em;
  }
  .frac-num {
    font-size: 0.9em;
    font-weight: 900;
    color: #fde68a;
    line-height: 1.2;
    padding: 0 0.2em 0.05em;
    border-bottom: 2.5px solid #fbbf24;
    min-width: 1em;
    text-align: center;
    letter-spacing: 0;
  }
  .frac-den {
    font-size: 0.9em;
    font-weight: 900;
    color: #fde68a;
    line-height: 1.2;
    padding: 0.05em 0.2em 0;
    min-width: 1em;
    text-align: center;
    letter-spacing: 0;
  }

  .fruits-container {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
  }

  .fruit-btn {
    border-radius: 28px;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    min-width: 170px;
    font-size: 2rem;
    font-weight: 800;
    padding: 1.4rem 2rem;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.3);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #ffffff !important;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
  }

  .fruit-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.3),
      transparent
    );
    transition: all 0.6s ease;
    transform: skewX(-25deg);
  }

  .fruit-btn:hover::before {
    left: 150%;
  }

  .fruit-btn:hover {
    transform: translateY(-8px) scale(1.03);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.2);
  }

  .fruit-btn.blue-card {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.5), rgba(59, 130, 246, 0.2));
    border: 1px solid rgba(59, 130, 246, 0.5);
  }

  .fruit-btn.green-card {
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.5), rgba(16, 185, 129, 0.2));
    border: 1px solid rgba(16, 185, 129, 0.5);
  }

  .fruit-btn.red-card {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.5), rgba(239, 68, 68, 0.2));
    border: 1px solid rgba(239, 68, 68, 0.5);
  }

  .fruit-btn.yellow-card {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.55), rgba(245, 158, 11, 0.25));
    border: 1px solid rgba(245, 158, 11, 0.5);
  }

  .fruit-btn:active {
    transform: translateY(-2px) scale(0.98);
  }

  .feedback {
    font-size: 1.5rem;
    font-weight: bold;
    margin-top: 2rem;
    min-height: 2rem;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  }

  .correct {
    color: #22c55e;
    animation: correctPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .incorrect {
    color: #ef4444;
    animation: shake 0.5s ease;
  }

  @keyframes correctPop {
    0% { transform: scale(0.5); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-10px); }
    75% { transform: translateX(10px); }
  }

  @media (max-width: 600px) {
    .header-beta {
      flex-direction: column;
      gap: 0.8rem;
      margin-bottom: 1rem;
    }

    .level-title {
      font-size: 1.8rem;
    }

    .timer-box {
      font-size: 1.1rem;
      padding: 0.4rem 1rem;
      border-radius: 12px;
    }

    .screen {
      padding: 1.5rem 1rem;
      border-radius: 20px;
      margin-bottom: 1.5rem;
      min-width: 0;
      width: 100%;
      box-sizing: border-box;
    }

    #math-question {
      font-size: 2.5rem;
      letter-spacing: 2px;
    }

    .fruits-container {
      gap: 1rem;
      width: 100%;
    }

    :global(.fruit-btn) {
      min-width: 0;
      width: 100%;
      box-sizing: border-box;
      font-size: 1.4rem;
      padding: 1.1rem 1.5rem;
      border-radius: 16px;
    }
  }

  @media (max-width: 360px) {
    #math-question {
      font-size: 2rem;
    }
    :global(.fruit-btn) {
      font-size: 1.2rem;
    }
  }
</style>

<script>
  //@ts-ignore
  import confetti from 'canvas-confetti';
  import { turnManager } from '../lib/turnManager';
  import { ChallengePool } from '../utils/fracGeo';

  // Pool de retos sin repetición – se rota todo el catálogo antes de volver a repetir
  const challengePool = new ChallengePool('6to', 3);
  import { generateMathQuestion } from '../utils/mathGenerator';

  // Inicializar TurnManager y UI
  try {
    turnManager.inicializar();
    updateTurnUI();
  } catch (e) {
    console.warn("Faltan datos de configuración, redirigiendo a Setup...");
    window.location.href = '/Setup';
  }

  function updateTurnUI() {
    try {
      const turnInfo = turnManager.obtenerTurnoActual();
      const indicator = document.getElementById('turn-indicator');
      const avatarEl = document.getElementById('turn-avatar');
      const teamEl = document.getElementById('turn-team');
      const memberEl = document.getElementById('turn-member');

      if (indicator && avatarEl && teamEl && memberEl) {
        indicator.classList.remove('hidden');
        avatarEl.textContent = turnInfo.equipo.avatar;
        teamEl.textContent = turnInfo.equipo.name;
        teamEl.style.color = turnInfo.equipo.hexColor;
        memberEl.textContent = turnInfo.miembro;
        indicator.style.borderColor = turnInfo.equipo.hexColor;
        indicator.style.boxShadow = `0 8px 32px ${turnInfo.equipo.hexColor}40`;
      }
    } catch (e) {
      console.error("Error al actualizar UI de turno:", e);
    }
  }

  const questionEl = document.getElementById('math-question');
  const optionsContainer = document.getElementById('options-container');
  const feedbackEl = document.getElementById('feedback-message');
  const timeLeftEl = document.getElementById('time-left');
  const timerBox = document.querySelector('.timer-box');

  // --- VARIABLES DE CONTROL DEL MODAL (NUEVO) ---
  const rulesModal = document.getElementById('rules-modal');
  const btnCloseRules = document.getElementById('btn-close-rules');
  let modalAbierto = true; // Flag para impedir que corra el tiempo al inicio

  let timer: ReturnType<typeof setInterval> | undefined;
  let timeLeft = 15;
  let isAnswering = false;

  function startTimer(duration: number = 15) {
    if (modalAbierto) return; // Si las reglas están en pantalla, NO iniciamos el reloj
    
    timeLeft = duration;
    if (timeLeftEl) timeLeftEl.textContent = timeLeft.toString();
    if (timerBox) timerBox.classList.remove('timer-warning');
    clearInterval(timer);

    const warnAt = duration > 30 ? 10 : 5;

    timer = setInterval(() => {
      timeLeft--;
      if (timeLeftEl) timeLeftEl.textContent = timeLeft.toString();

      if (timeLeft <= warnAt && timerBox) {
        timerBox.classList.add('timer-warning');
      }

      if (timeLeft <= 0) {
        clearInterval(timer);
        handleTimeOut();
      }
    }, 1000);
  }

  function handleTimeOut() {
    isAnswering = true;

    try {
      turnManager.comenzarTurno();
      turnManager.resolverTurno({ fueCorrecto: false });
    } catch(e) { console.error(e) }

    if (feedbackEl) {
      feedbackEl.textContent = "¡Tiempo agotado!";
      feedbackEl.className = "feedback incorrect";
    }
    setTimeout(() => {
      try {
        turnManager.siguienteTurno();
        updateTurnUI();
      } catch(e) { console.error(e) }
      generateQuestion();
    }, 2000);
  }

  function generateQuestion() {
    isAnswering = false;
    if (feedbackEl) feedbackEl.textContent = "";

    // 50% de probabilidad de usar un reto de fracciones/geometría y 50% de operaciones simples
    const useChallenge = Math.random() > 0.5;

    if (useChallenge) {
      const challenge = challengePool.next();
      if (questionEl) {
        questionEl.innerHTML = challenge.htmlQuestion;
        questionEl.style.fontSize = '';
        questionEl.style.letterSpacing = '';
      }
      startTimer(challenge.timeLimit);
      renderOptions(challenge.options);
    } else {
      const question = generateMathQuestion('Beta');

      if (questionEl) {
        // Restaurar estilos para preguntas normales
        questionEl.style.fontSize = '4rem';
        questionEl.style.letterSpacing = '5px';
        questionEl.textContent = question.text;
      }

      renderOptions(question.options);
      startTimer(15);
    }
  }

  function renderOptions(options: { value: number; isCorrect: boolean }[]) {
    if (!optionsContainer) return;
    optionsContainer.innerHTML = '';

    const labels = ['A', 'B', 'C'];
    const colorClasses = ['blue-card', 'green-card', 'red-card', 'yellow-card'];

    options.forEach((opt, index) => {
      const btn = document.createElement('button');
      btn.className = `fruit-btn ${colorClasses[index % colorClasses.length]}`;
      btn.textContent = `Opción ${labels[index]}: ${opt.value}`;

      btn.addEventListener('click', () => {
        if (!isAnswering) checkAnswer(opt.isCorrect);
      });

      optionsContainer.appendChild(btn);
    });
  }

  function checkAnswer(isCorrect: boolean) {
    isAnswering = true;
    clearInterval(timer);

    if (!feedbackEl || !optionsContainer) return;

    try {
      turnManager.comenzarTurno();
      turnManager.resolverTurno({ fueCorrecto: isCorrect });
    } catch(e) { console.error(e) }

    if (isCorrect) {
      feedbackEl.textContent = "¡Correcto!";
      feedbackEl.className = "feedback correct";

      const audioGanar = new Audio('/sounds/Ganar.mp3');
      audioGanar.play();

      confetti({
        particleCount: 150,
        spread: 80,
        origin: { y: 0.6 }
      });

      optionsContainer.style.display = 'none'; 
      document.dispatchEvent(new CustomEvent('respuestaCorrecta'));

    } else {
      feedbackEl.textContent = "Intenta de nuevo";
      feedbackEl.className = "feedback incorrect";

      const audioPerder = new Audio('/sounds/perder.mp3');
      audioPerder.play();

      for (let i = 0; i < 10; i++) {
        const x = document.createElement('div');
        x.textContent = '❌'; 
        x.style.position = 'fixed';
        x.style.top = '-50px';
        x.style.left = Math.random() * 100 + 'vw'; 
        x.style.fontSize = Math.random() * (30 - 20) + 20 + 'px';
        x.style.zIndex = '9999';
        x.style.pointerEvents = 'none';
        x.style.transition = 'transform 1s linear, opacity 1s ease';
        
        document.body.appendChild(x);

        setTimeout(() => {
          x.style.transform = `translateY(110vh) rotate(${Math.random() * 360}deg)`;
          x.style.opacity = '0';
          setTimeout(() => x.remove(), 1000);
        }, Math.random() * 200);
      }
  
      setTimeout(() => {
        try {
          turnManager.siguienteTurno();
          updateTurnUI();
        } catch(e) { console.error(e) }
        generateQuestion();
      }, 1500);
    }
  }

  // Lógica para cerrar el Modal e iniciar formalmente el conteo regresivo
  if (btnCloseRules && rulesModal) {
    btnCloseRules.addEventListener('click', () => {
      rulesModal.classList.add('modal-fade-out');
      setTimeout(() => {
        rulesModal.style.display = 'none';
        modalAbierto = false; // Desbloquea el reloj
        startTimer();        // Activa los 15 segundos ahora sí
      }, 400);
    });
  }

  document.addEventListener('siguienteTurno', () => {
    try {
      turnManager.siguienteTurno();
      updateTurnUI();
    } catch(e) { console.error(e) }

    if (feedbackEl) feedbackEl.textContent = "";
    if (optionsContainer) optionsContainer.style.display = 'flex'; 
    generateQuestion(); 
  });

  document.addEventListener('avanzarFicha', (e: any) => {
    console.log(`Beta: El jugador saca dado de ${e.detail.pasos}. Mover ficha.`);
  });

  // Genera la pregunta base (las respuestas se pintan pero el reloj esperará el clic del modal)
  generateQuestion();

</script>
