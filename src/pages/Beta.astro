import Layout from '../layouts/Layout.astro';

<Layout>
  <div class="game-container">
    <div class="header-beta">
      <h1 class="level-title">Nivel Beta</h1>
      <div class="timer-box">
        <span id="time-left">15</span>s
      </div>
    </div>

    <div class="screen">
      <h2 id="math-question">Cargando...</h2>
    </div>

    <div class="fruits-container" id="options-container">
    </div>

    <p id="feedback-message" class="feedback"></p>
  </div>
</Layout>

<style>
  .game-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-top: 2rem;
    animation: fadeInUp 0.6s ease-out;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .header-beta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: 600px;
    margin-bottom: 1.5rem;
  }

  .level-title {
    font-size: 2.2rem;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 3px;
    background: linear-gradient(135deg, #22D3EE, #3B82F6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(2px 2px 4px rgba(59, 130, 246, 0.3));
  }

  .timer-box {
    background: linear-gradient(135deg, #EF4444, #F97316);
    color: #fff;
    padding: 0.6rem 1.2rem;
    border-radius: 16px;
    font-size: 1.3rem;
    font-weight: 700;
    font-family: 'Fredoka', monospace;
    box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4);
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: transform 0.2s ease;
  }

  :global(.timer-warning) {
    animation: timerPulse 0.5s ease-in-out infinite;
    background: linear-gradient(135deg, #DC2626, #EF4444) !important;
  }

  @keyframes timerPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }

  .screen {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    color: #1e3a5f;
    padding: 2rem 4rem;
    border-radius: 24px;
    box-shadow: 
      0 8px 32px rgba(59, 130, 246, 0.2),
      inset 0 0 0 4px rgba(59, 130, 246, 0.2);
    margin-bottom: 2rem;
    min-width: 300px;
    position: relative;
  }

  .screen::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 28px;
    background: linear-gradient(135deg, #22D3EE, #3B82F6, #8B5CF6, #EC4899);
    z-index: -1;
    animation: borderGlow 3s ease-in-out infinite;
  }

  @keyframes borderGlow {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  #math-question {
    font-size: 4rem;
    margin: 0;
    font-family: 'Fredoka', monospace;
    letter-spacing: 5px;
    color: #1e1b4b;
  }

  .fruits-container {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  :global(.fruit-btn) {
    background: linear-gradient(135deg, #22D3EE, #3B82F6);
    border: none;
    color: #fff;
    font-size: 2.2rem;
    font-weight: 700;
    padding: 1.2rem 2rem;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    min-width: 130px;
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.3);
    position: relative;
    overflow: hidden;
  }

  :global(.fruit-btn::before) {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.3) 0%, transparent 50%);
    pointer-events: none;
  }

  :global(.fruit-btn:hover) {
    transform: translateY(-8px) scale(1.05);
    box-shadow: 0 12px 30px rgba(59, 130, 246, 0.5);
  }

  :global(.fruit-btn:active) {
    transform: translateY(-2px) scale(0.98);
  }

  .feedback {
    font-size: 1.5rem;
    font-weight: bold;
    margin-top: 2rem;
    min-height: 2rem;
  }

  :global(.correct) {
    color: #16a34a;
    animation: correctPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  :global(.incorrect) {
    color: #ef4444;
    animation: shake 0.5s ease;
  }

  @keyframes correctPop {
    0% { transform: scale(0.5); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-10px); }
    75% { transform: translateX(10px); }
  }
</style>

<script>
  const questionEl = document.getElementById('math-question');
  const optionsContainer = document.getElementById('options-container');
  const feedbackEl = document.getElementById('feedback-message');
  const timeLeftEl = document.getElementById('time-left');
  const timerBox = document.querySelector('.timer-box');

  let timer: ReturnType<typeof setInterval> | undefined;
  let timeLeft = 15;
  let isAnswering = false;

  function startTimer() {
    timeLeft = 15;
    if (timeLeftEl) timeLeftEl.textContent = timeLeft.toString();
    if (timerBox) timerBox.classList.remove('timer-warning');
    clearInterval(timer);

    timer = setInterval(() => {
      timeLeft--;
      if (timeLeftEl) timeLeftEl.textContent = timeLeft.toString();

      if (timeLeft <= 5 && timerBox) {
        timerBox.classList.add('timer-warning');
      }

      if (timeLeft <= 0) {
        clearInterval(timer);
        handleTimeOut();
      }
    }, 1000);
  }

  function handleTimeOut() {
    if (isAnswering) return;
    isAnswering = true;
    
    if (feedbackEl) {
      feedbackEl.textContent = "¡Tiempo agotado!";
      feedbackEl.className = "feedback incorrect";
    }
    
    setTimeout(() => {
      generateQuestion();
    }, 1500);
  }

  function generateSmartDistractors(v1: number, v2: number, correct: number, isMultiplication: boolean) {
    const distractors = new Set<number>();
    
    if (isMultiplication) {
      if (v1 + v2 !== correct) distractors.add(v1 + v2);
      distractors.add(v1 * (v2 + 1));
      if (v2 > 1) distractors.add(v1 * (v2 - 1));
    } else {
      if (v1 * v2 !== correct) distractors.add(v1 * v2);
      distractors.add(correct + 2);
    }

    distractors.add(correct + 1);
    if (correct > 1) distractors.add(correct - 1);
    distractors.add(correct + 10);

    return Array.from(distractors)
      .filter(d => d !== correct && d > 0)
      .slice(0, 2); 
  }

  function generateQuestion() {
    isAnswering = false;
    if (feedbackEl) feedbackEl.textContent = "";

    const isMultiplication = Math.random() > 0.5;
    let var1, var2, correctAnswer, operator;

    if (isMultiplication) {
      var1 = Math.floor(Math.random() * 10) + 2;
      var2 = Math.floor(Math.random() * 10) + 2;
      correctAnswer = var1 * var2;
      operator = '×';
    } else {
      var2 = Math.floor(Math.random() * 9) + 2;
      correctAnswer = Math.floor(Math.random() * 10) + 2;
      var1 = correctAnswer * var2;
      operator = '÷';
    }

    const distractors = generateSmartDistractors(var1, var2, correctAnswer, isMultiplication);

    const options = [
      { value: correctAnswer, isCorrect: true },
      { value: distractors[0], isCorrect: false },
      { value: distractors[1], isCorrect: false }
    ];

    options.sort(() => Math.random() - 0.5);

    if (questionEl) {
      questionEl.textContent = `${var1} ${operator} ${var2} = ?`;
    }

    renderOptions(options);
    startTimer();
  }

  function renderOptions(options: { value: number; isCorrect: boolean }[]) {
    if (!optionsContainer) return;
    optionsContainer.innerHTML = '';

    const labels = ['A', 'B', 'C'];

    options.forEach((opt, index) => {
      const btn = document.createElement('button');
      btn.className = 'fruit-btn';
      btn.textContent = `Opción ${labels[index]}: ${opt.value}`;

      btn.addEventListener('click', () => {
        if (!isAnswering) checkAnswer(opt.isCorrect, btn);
      });

      optionsContainer.appendChild(btn);
    });
  }

  function checkAnswer(isCorrect: boolean, btnElement: HTMLButtonElement) {
    if (isAnswering) return;
    isAnswering = true;
    clearInterval(timer);

    if (!feedbackEl) return;

    if (isCorrect) {
      feedbackEl.textContent = "¡Correcto!";
      feedbackEl.className = "feedback correct";
      btnElement.style.background = "#16a34a"; 

      setTimeout(() => { generateQuestion(); }, 1500);
    } else {
      feedbackEl.textContent = "Intenta de nuevo";
      feedbackEl.className = "feedback incorrect";
      btnElement.style.background = "#ef4444"; 
      btnElement.style.transform = "scale(0.95)";
      
      setTimeout(() => { generateQuestion(); }, 1500);
    }
  }

  generateQuestion();
</script>
