---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="setup-container">
    <div class="setup-card">
      <div class="setup-header">
        <a href="/" class="back-link">
          <span class="back-arrow">←</span> Volver al Inicio
        </a>
        <h1 class="setup-title">Configuración de la Partida</h1>
        <p class="setup-subtitle">¡Prepara a tus equipos y prepárate para jugar!</p>
      </div>

      <!-- SECCIÓN 1: Selección de Nivel -->
      <div class="setup-section">
        <h3 class="section-title">
          <span class="step-num">1</span> Selecciona el Nivel de Dificultad
        </h3>
        <div class="level-selection-container">
          <button type="button" class="level-btn active" id="btn-level-alpha" data-level="Alpha">
            <span class="level-icon">🍎</span>
            <div class="level-text-container">
              <span class="level-name">Nivel Alfa</span>
              <span class="level-desc">Sumas y Restas (6-8 años)</span>
            </div>
          </button>

          <button type="button" class="level-btn" id="btn-level-beta" data-level="Beta">
            <span class="level-icon">🚀</span>
            <div class="level-text-container">
              <span class="level-name">Nivel Beta</span>
              <span class="level-desc">Multiplicación y División (9-12 años)</span>
            </div>
          </button>
        </div>
      </div>

      <!-- SECCIÓN 2: Cantidad de Equipos -->
      <div class="setup-section">
        <h3 class="section-title">
          <span class="step-num">2</span> ¿Cuántos equipos van a jugar?
        </h3>
        <div class="qty-selection-container">
          <button type="button" class="qty-btn" data-qty="2">2 Equipos</button>
          <button type="button" class="qty-btn active" data-qty="3">3 Equipos</button>
          <button type="button" class="qty-btn" data-qty="4">4 Equipos</button>
        </div>
      </div>

      <!-- SECCIÓN 3: Personalizar Equipos -->
      <div class="setup-section">
        <h3 class="section-title">
          <span class="step-num">3</span> Personaliza tus Equipos e Integrantes
        </h3>
        <div class="teams-grid" id="teams-grid">
          
          <!-- TARJETA EQUIPO 1 (Azul) -->
          <div class="team-card team-blue" id="team-card-1">
            <div class="card-header">
              <div class="avatar-preview-circle" id="preview-avatar-1">🦁</div>
              <input 
                type="text" 
                class="team-name-input" 
                id="team-name-1" 
                value="Equipo León" 
                placeholder="Nombre del Equipo 1"
                maxlength="20"
              />
            </div>
            <div class="avatar-picker-section">
              <span class="picker-label">Elige Mascota:</span>
              <div class="avatar-options" data-team-id="1">
                <button type="button" class="avatar-opt-btn active" data-emoji="🦁">🦁</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🦊">🦊</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐼">🐼</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐨">🐨</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐸">🐸</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐙">🐙</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🦖">🦖</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🦄">🦄</button>
              </div>
            </div>
            <div class="members-section">
              <span class="picker-label">¿Cuántos integrantes?</span>
              <div class="members-counter-wrapper">
                <button type="button" class="counter-btn minus-btn" data-team-id="1">−</button>
                <span class="counter-value" id="member-count-1">1</span>
                <button type="button" class="counter-btn plus-btn" data-team-id="1">+</button>
              </div>
              <div class="visual-members-container" id="visual-members-1">
                <!-- Se llena con emojis desde JS -->
              </div>
            </div>
          </div>

          <!-- TARJETA EQUIPO 2 (Naranja) -->
          <div class="team-card team-orange" id="team-card-2">
            <div class="card-header">
              <div class="avatar-preview-circle" id="preview-avatar-2">🦊</div>
              <input 
                type="text" 
                class="team-name-input" 
                id="team-name-2" 
                value="Equipo Zorro" 
                placeholder="Nombre del Equipo 2"
                maxlength="20"
              />
            </div>
            <div class="avatar-picker-section">
              <span class="picker-label">Elige Mascota:</span>
              <div class="avatar-options" data-team-id="2">
                <button type="button" class="avatar-opt-btn" data-emoji="🦁">🦁</button>
                <button type="button" class="avatar-opt-btn active" data-emoji="🦊">🦊</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐼">🐼</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐨">🐨</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐸">🐸</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐙">🐙</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🦖">🦖</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🦄">🦄</button>
              </div>
            </div>
            <div class="members-section">
              <span class="picker-label">¿Cuántos integrantes?</span>
              <div class="members-counter-wrapper">
                <button type="button" class="counter-btn minus-btn" data-team-id="2">−</button>
                <span class="counter-value" id="member-count-2">1</span>
                <button type="button" class="counter-btn plus-btn" data-team-id="2">+</button>
              </div>
              <div class="visual-members-container" id="visual-members-2">
                <!-- Se llena con emojis desde JS -->
              </div>
            </div>
          </div>

          <!-- TARJETA EQUIPO 3 (Verde) -->
          <div class="team-card team-green" id="team-card-3">
            <div class="card-header">
              <div class="avatar-preview-circle" id="preview-avatar-3">🐼</div>
              <input 
                type="text" 
                class="team-name-input" 
                id="team-name-3" 
                value="Equipo Panda" 
                placeholder="Nombre del Equipo 3"
                maxlength="20"
              />
            </div>
            <div class="avatar-picker-section">
              <span class="picker-label">Elige Mascota:</span>
              <div class="avatar-options" data-team-id="3">
                <button type="button" class="avatar-opt-btn" data-emoji="🦁">🦁</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🦊">🦊</button>
                <button type="button" class="avatar-opt-btn active" data-emoji="🐼">🐼</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐨">🐨</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐸">🐸</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐙">🐙</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🦖">🦖</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🦄">🦄</button>
              </div>
            </div>
            <div class="members-section">
              <span class="picker-label">¿Cuántos integrantes?</span>
              <div class="members-counter-wrapper">
                <button type="button" class="counter-btn minus-btn" data-team-id="3">−</button>
                <span class="counter-value" id="member-count-3">1</span>
                <button type="button" class="counter-btn plus-btn" data-team-id="3">+</button>
              </div>
              <div class="visual-members-container" id="visual-members-3">
                <!-- Se llena con emojis desde JS -->
              </div>
            </div>
          </div>

          <!-- TARJETA EQUIPO 4 (Morado) -->
          <div class="team-card team-purple" id="team-card-4">
            <div class="card-header">
              <div class="avatar-preview-circle" id="preview-avatar-4">🐨</div>
              <input 
                type="text" 
                class="team-name-input" 
                id="team-name-4" 
                value="Equipo Koala" 
                placeholder="Nombre del Equipo 4"
                maxlength="20"
              />
            </div>
            <div class="avatar-picker-section">
              <span class="picker-label">Elige Mascota:</span>
              <div class="avatar-options" data-team-id="4">
                <button type="button" class="avatar-opt-btn" data-emoji="🦁">🦁</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🦊">🦊</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐼">🐼</button>
                <button type="button" class="avatar-opt-btn active" data-emoji="🐨">🐨</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐸">🐸</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🐙">🐙</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🦖">🦖</button>
                <button type="button" class="avatar-opt-btn" data-emoji="🦄">🦄</button>
              </div>
            </div>
            <div class="members-section">
              <span class="picker-label">¿Cuántos integrantes?</span>
              <div class="members-counter-wrapper">
                <button type="button" class="counter-btn minus-btn" data-team-id="4">−</button>
                <span class="counter-value" id="member-count-4">1</span>
                <button type="button" class="counter-btn plus-btn" data-team-id="4">+</button>
              </div>
              <div class="visual-members-container" id="visual-members-4">
                <!-- Se llena con emojis desde JS -->
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Botón Comenzar y Caja de Validación -->
      <div class="actions-section">
        <div id="error-message" class="error-toast hidden">
          ⚠️ Por favor solucione los errores antes de comenzar.
        </div>
        <button type="button" id="btn-start" class="btn-start-adventure">
          ¡Comenzar Aventura! 🎲
        </button>
      </div>

    </div>
  </div>
</Layout>

<style is:global>
  .setup-container {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1rem 0;
    animation: fadeInDown 0.6s ease-out;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .setup-card {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.45), rgba(30, 41, 59, 0.25));
    backdrop-filter: blur(25px) saturate(180%);
    -webkit-backdrop-filter: blur(25px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 32px;
    padding: 2.5rem;
    width: 100%;
    max-width: 950px;
    box-shadow: 
      0 24px 60px rgba(0, 0, 0, 0.4), 
      inset 0 1px 1px rgba(255, 255, 255, 0.12),
      inset 0 -1px 2px rgba(255, 255, 255, 0.05),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    position: relative;
    overflow: hidden;
  }

  /* Brillo de vidrio líquido para la tarjeta de configuración */
  .setup-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -150%;
    width: 200%;
    height: 100%;
    background: linear-gradient(
      115deg,
      transparent 35%,
      rgba(255, 255, 255, 0.15) 40%,
      rgba(255, 255, 255, 0.35) 45%,
      rgba(255, 255, 255, 0.15) 50%,
      transparent 55%
    );
    transform: skewX(-20deg);
    transition: all 1.5s cubic-bezier(0.19, 1, 0.22, 1);
    pointer-events: none;
    z-index: 1;
  }

  .setup-card:hover::before {
    left: 150%;
  }

  .setup-header {
    position: relative;
    z-index: 2;
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .back-link {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    text-decoration: none;
    color: #a78bfa;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 1.05rem;
    transition: all 0.2s ease;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }

  .back-link:hover {
    color: #c084fc;
    transform: translateY(-50%) translateX(-4px);
  }

  .setup-title {
    font-size: 2.4rem;
    color: #f8fafc;
    margin: 0 0 0.5rem 0;
    font-weight: 800;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .setup-subtitle {
    font-size: 1.1rem;
    color: #cbd5e1;
    margin: 0;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
  }

  .setup-section {
    position: relative;
    z-index: 2;
    margin-bottom: 2.5rem;
    border-bottom: 2px dashed rgba(255, 255, 255, 0.1);
    padding-bottom: 2.5rem;
  }

  .setup-section:last-of-type {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 1.4rem;
    color: #f1f5f9;
    margin: 0 0 1.5rem 0;
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
    text-shadow: 0 1px 3px rgba(0,0,0,0.5);
  }

  .step-num {
    background: linear-gradient(135deg, #7C3AED, #9333EA);
    color: #fff;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 1.1rem;
    font-weight: 700;
    box-shadow: 0 4px 10px rgba(124, 58, 237, 0.3);
  }

  /* Nivel Selection */
  .level-selection-container {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .level-btn {
    flex: 1;
    min-width: 250px;
    background: rgba(255, 255, 255, 0.08);
    border: 2px solid rgba(255, 255, 255, 0.15);
    border-radius: 20px;
    padding: 1.2rem 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 18px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    text-align: left;
    backdrop-filter: blur(5px);
    color: #e2e8f0;
  }

  .level-btn:hover {
    transform: translateY(-5px);
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.12);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
  }

  .level-btn.active {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.2), rgba(192, 132, 252, 0.2));
    border-color: #a78bfa;
    box-shadow: 0 8px 24px rgba(124, 58, 237, 0.25);
  }

  .level-icon {
    font-size: 2.2rem;
    filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.3));
    transition: transform 0.3s ease;
  }

  .level-btn:hover .level-icon {
    transform: rotate(10deg) scale(1.1);
  }

  .level-text-container {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .level-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: #f8fafc;
  }

  .level-desc {
    font-size: 0.9rem;
    color: #94a3b8;
  }

  /* Cantidad de Equipos */
  .qty-selection-container {
    display: flex;
    gap: 1.2rem;
  }

  .qty-btn {
    flex: 1;
    background: rgba(255, 255, 255, 0.08);
    border: 2px solid rgba(255, 255, 255, 0.15);
    border-radius: 16px;
    padding: 1rem;
    font-size: 1.15rem;
    font-weight: 700;
    color: #f1f5f9;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    backdrop-filter: blur(5px);
  }

  .qty-btn:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.12);
  }

  .qty-btn.active {
    background: linear-gradient(135deg, #7C3AED, #9333EA);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 8px 20px rgba(124, 58, 237, 0.35);
  }

  /* Grid de Equipos */
  .teams-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .team-card {
    border-radius: 24px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    transition: all 0.3s ease;
    position: relative;
    border: 2px solid transparent;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  /* Colores temáticos de equipos en formato Liquid Glass */
  .team-blue {
    border-color: rgba(59, 130, 246, 0.4);
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.18), rgba(15, 23, 42, 0.35));
  }
  .team-blue:focus-within, .team-blue.active-glow {
    border-color: #3B82F6;
    box-shadow: 0 12px 30px rgba(59, 130, 246, 0.35);
  }

  .team-orange {
    border-color: rgba(249, 115, 22, 0.4);
    background: linear-gradient(135deg, rgba(249, 115, 22, 0.18), rgba(15, 23, 42, 0.35));
  }
  .team-orange:focus-within, .team-orange.active-glow {
    border-color: #F97316;
    box-shadow: 0 12px 30px rgba(249, 115, 22, 0.35);
  }

  .team-green {
    border-color: rgba(16, 185, 129, 0.4);
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.18), rgba(15, 23, 42, 0.35));
  }
  .team-green:focus-within, .team-green.active-glow {
    border-color: #10B981;
    box-shadow: 0 12px 30px rgba(16, 185, 129, 0.35);
  }

  .team-purple {
    border-color: rgba(139, 92, 246, 0.4);
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.18), rgba(15, 23, 42, 0.35));
  }
  .team-purple:focus-within, .team-purple.active-glow {
    border-color: #8B5CF6;
    box-shadow: 0 12px 30px rgba(139, 92, 246, 0.35);
  }

  /* Animación de ocultar tarjeta */
  .team-card.hidden-card {
    display: none !important;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .avatar-preview-circle {
    width: 50px;
    height: 50px;
    background: rgba(15, 23, 42, 0.6);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    border: 2px solid rgba(255, 255, 255, 0.1);
  }

  .team-name-input {
    flex: 1;
    background: rgba(15, 23, 42, 0.5);
    border: 2px solid rgba(255, 255, 255, 0.15);
    border-radius: 12px;
    padding: 0.6rem 0.8rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff;
    outline: none;
    transition: all 0.2s ease;
  }

  .team-name-input:focus {
    background: rgba(15, 23, 42, 0.7);
    border-color: #a78bfa;
    box-shadow: 0 0 0 3px rgba(167, 139, 250, 0.25);
  }

  /* Avatar Picker */
  .avatar-picker-section {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .picker-label {
    font-size: 0.9rem;
    font-weight: 700;
    color: #94a3b8;
    margin-bottom: 2px;
  }

  .avatar-options {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .avatar-opt-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(15, 23, 42, 0.5);
    cursor: pointer;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
  }

  .avatar-opt-btn:hover {
    transform: scale(1.2);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .avatar-opt-btn.active {
    transform: scale(1.25);
    border-color: #a78bfa;
    box-shadow: 0 4px 10px rgba(167, 139, 250, 0.4);
    z-index: 2;
  }

  /* Integrantes (Contadores para niños) */
  .members-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
    align-items: center;
    text-align: center;
  }

  .members-counter-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    background: rgba(255, 255, 255, 0.6);
    border: 2px solid rgba(124, 58, 237, 0.15);
    border-radius: 20px;
    padding: 6px 14px;
    width: fit-content;
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.03);
  }

  .counter-btn {
    background: linear-gradient(135deg, #7C3AED, #9333EA);
    color: #fff;
    border: none;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    font-size: 1.5rem;
    font-weight: 800;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 8px rgba(124, 58, 237, 0.2);
    user-select: none;
    line-height: 1;
    padding-bottom: 2px;
  }

  .counter-btn:hover:not(:disabled) {
    transform: scale(1.18);
    box-shadow: 0 6px 12px rgba(124, 58, 237, 0.35);
  }

  .counter-btn:active:not(:disabled) {
    transform: scale(0.9);
  }

  .counter-btn:disabled {
    background: #d1d5db;
    color: #9ca3af;
    cursor: not-allowed;
    box-shadow: none;
  }

  .counter-value {
    font-size: 1.8rem;
    font-weight: 800;
    color: #2D1B4E;
    min-width: 32px;
    user-select: none;
  }

  /* Contenedor Visual de Integrantes */
  .visual-members-container {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    min-height: 52px;
    padding: 8px;
    background: rgba(255, 255, 255, 0.4);
    border-radius: 16px;
    width: 100%;
    box-sizing: border-box;
    border: 2px dashed rgba(124, 58, 237, 0.15);
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .visual-member-avatar {
    font-size: 2.2rem;
    display: inline-block;
    animation: avatarPopIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.15));
    cursor: default;
    user-select: none;
    transition: transform 0.2s ease;
  }

  .visual-member-avatar:hover {
    transform: scale(1.25) rotate(12deg);
  }

  @keyframes avatarPopIn {
    0% {
      transform: scale(0) rotate(-30deg);
      opacity: 0;
    }
    100% {
      transform: scale(1) rotate(0deg);
      opacity: 1;
    }
  }

  .empty-warning {
    font-size: 0.85rem;
    color: #ea580c;
    margin: 4px 0 0 0;
    font-weight: 500;
    display: none;
  }

  .empty-warning.visible-warning {
    display: block;
    animation: shake 0.4s ease;
  }

  /* Acciones de envío */
  .actions-section {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .error-toast {
    background: #fef2f2;
    border: 2px solid #fca5a5;
    color: #dc2626;
    padding: 0.8rem 1.5rem;
    border-radius: 16px;
    font-weight: 700;
    font-size: 1rem;
    box-shadow: 0 4px 12px rgba(220, 38, 38, 0.1);
    animation: shake 0.5s ease;
  }

  .error-toast.hidden {
    display: none !important;
  }

  .btn-start-adventure {
    background: linear-gradient(135deg, #10B981, #059669);
    color: #fff;
    border: none;
    font-size: 1.6rem;
    font-weight: 800;
    padding: 1.2rem 3.5rem;
    border-radius: 24px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 8px 24px rgba(16, 185, 129, 0.4);
  }

  .btn-start-adventure:hover {
    transform: translateY(-8px) scale(1.03);
    box-shadow: 0 15px 35px rgba(16, 185, 129, 0.55);
  }

  .btn-start-adventure:active {
    transform: translateY(-2px) scale(0.98);
  }

  /* Shaking Animation for errors */
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-8px); }
    75% { transform: translateX(8px); }
  }

  .shake-anim {
    animation: shake 0.4s ease;
  }

  @media (max-width: 650px) {
    .setup-container {
      padding: 0.5rem 0;
    }

    .setup-card {
      padding: 1.5rem 1rem;
      border-radius: 24px;
      margin: 0;
    }

    .back-link {
      position: static;
      transform: none;
      margin-bottom: 1.2rem;
      justify-content: center;
    }

    .setup-header {
      margin-bottom: 1.5rem;
    }

    .setup-title {
      font-size: 1.7rem;
    }

    .setup-subtitle {
      font-size: 0.95rem;
    }

    .setup-section {
      margin-bottom: 1.8rem;
      padding-bottom: 1.8rem;
    }

    .section-title {
      font-size: 1.15rem;
      margin-bottom: 1rem;
      gap: 8px;
    }

    .step-num {
      width: 28px;
      height: 28px;
      font-size: 0.95rem;
    }

    .level-selection-container {
      flex-direction: column;
      gap: 1rem;
    }

    .level-btn {
      min-width: 0;
      padding: 1rem;
      gap: 12px;
      border-radius: 16px;
    }

    .level-icon {
      font-size: 1.8rem;
    }

    .level-name {
      font-size: 1.1rem;
    }

    .level-desc {
      font-size: 0.8rem;
    }

    /* Mantenemos el selector de cantidad en fila pero más compacto en celular */
    .qty-selection-container {
      flex-direction: row;
      gap: 0.5rem;
    }

    .qty-btn {
      padding: 0.8rem 0.3rem;
      font-size: 0.95rem;
      border-radius: 12px;
      border-width: 2px;
    }

    /* Grid de equipos con ancho adaptado a teléfonos pequeños */
    .teams-grid {
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }

    .team-card {
      padding: 1rem;
      border-radius: 16px;
      gap: 1rem;
    }

    .team-name-input {
      padding: 0.5rem;
      font-size: 1rem;
      border-radius: 10px;
    }

    .avatar-preview-circle {
      width: 44px;
      height: 44px;
      font-size: 1.6rem;
    }

    .avatar-opt-btn {
      width: 28px;
      height: 28px;
      font-size: 1.1rem;
    }

    .member-text-input {
      padding: 0.45rem 0.6rem;
      font-size: 0.9rem;
      border-radius: 10px;
    }

    .add-member-btn {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      font-size: 1.2rem;
    }

    .member-chip {
      font-size: 0.8rem;
      padding: 0.25rem 0.5rem;
    }

    .btn-start-adventure {
      width: 100%;
      padding: 1rem 2rem;
      font-size: 1.3rem;
      border-radius: 16px;
    }
  }

  @media (max-width: 360px) {
    .qty-btn {
      font-size: 0.85rem;
    }
    .setup-title {
      font-size: 1.5rem;
    }
    .teams-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Estructura de estado en cliente
  interface Team {
    id: number;
    name: string;
    avatar: string;
    members: string[];
    colorClass: string;
    hexColor: string;
  }

  interface SetupState {
    level: string;
    qty: number;
    teams: Team[];
  }

  const emojiNames: Record<string, string> = {
    "🦁": "Equipo León",
    "🦊": "Equipo Zorro",
    "🐼": "Equipo Panda",
    "🐨": "Equipo Koala",
    "🐸": "Equipo Rana",
    "🐙": "Equipo Pulpo",
    "🦖": "Equipo Dino",
    "🦄": "Equipo Unicornio"
  };

  const state: SetupState = {
    level: 'Alpha',
    qty: 3,
    teams: [
      { id: 1, name: "Equipo León", avatar: "🦁", members: ["León 1"], colorClass: "team-blue", hexColor: "#3B82F6" },
      { id: 2, name: "Equipo Zorro", avatar: "🦊", members: ["Zorro 1"], colorClass: "team-orange", hexColor: "#F97316" },
      { id: 3, name: "Equipo Panda", avatar: "🐼", members: ["Panda 1"], colorClass: "team-green", hexColor: "#10B981" },
      { id: 4, name: "Equipo Koala", avatar: "🐨", members: ["Koala 1"], colorClass: "team-purple", hexColor: "#8B5CF6" }
    ]
  };

  // Elementos del DOM
  const btnLevelAlpha = document.getElementById('btn-level-alpha');
  const btnLevelBeta = document.getElementById('btn-level-beta');
  const qtyButtons = document.querySelectorAll('.qty-selection-container .qty-btn');
  const teamCards = [
    document.getElementById('team-card-1'),
    document.getElementById('team-card-2'),
    document.getElementById('team-card-3'),
    document.getElementById('team-card-4')
  ];
  const btnStart = document.getElementById('btn-start');
  const errorToast = document.getElementById('error-message');

  // Inicializar leyendo parámetros URL
  function init() {
    const urlParams = new URLSearchParams(window.location.search);
    const lvlParam = urlParams.get('level');
    
    if (lvlParam === 'Beta') {
      setLevel('Beta');
    } else {
      setLevel('Alpha');
    }

    // Por defecto inicializamos con 3 equipos
    setTeamQuantity(3);

    // Cargar configuraciones previas si existen
    loadFromLocalStorage();

    // Asegurarse de que cada equipo tenga al menos 1 integrante en su estado inicial
    state.teams.forEach((team) => {
      if (!team.members || team.members.length === 0) {
        const cleanName = team.name.replace("Equipo ", "");
        team.members = [`${cleanName} 1`];
      }
    });

    // Enlazar eventos de inputs, avatares y miembros
    bindEvents();
    
    // Renderizar contadores e integrantes visuales
    updateAllVisuals();
  }

  // Cargar desde LocalStorage para no reescribir
  function loadFromLocalStorage() {
    try {
      const saved = localStorage.getItem('serpientes_escaleras_setup');
      if (saved) {
        const parsed = JSON.parse(saved);
        if (parsed.level) setLevel(parsed.level);
        if (parsed.qty) setTeamQuantity(parsed.qty);
        if (parsed.teams && Array.isArray(parsed.teams)) {
          parsed.teams.forEach((t: any, index: number) => {
            if (index < state.teams.length) {
              if (t.name) {
                state.teams[index].name = t.name;
                const nameInput = document.getElementById(`team-name-${index + 1}`) as HTMLInputElement;
                if (nameInput) nameInput.value = t.name;
              }
              if (t.avatar) {
                state.teams[index].avatar = t.avatar;
                const preview = document.getElementById(`preview-avatar-${index + 1}`);
                if (preview) preview.textContent = t.avatar;

                // Actualizar botón activo de avatar
                const pickerContainer = document.querySelector(`.avatar-options[data-team-id="${index + 1}"]`);
                if (pickerContainer) {
                  pickerContainer.querySelectorAll('.avatar-opt-btn').forEach(btn => {
                    const btnEmoji = btn.getAttribute('data-emoji');
                    if (btnEmoji === t.avatar || (t.avatar === '🐨' && btnEmoji === 'Ko')) {
                      btn.classList.add('active');
                    } else {
                      btn.classList.remove('active');
                    }
                  });
                }
              }
              if (t.members) {
                state.teams[index].members = t.members;
              }
            }
          });
        }
      }
    } catch (e) {
      console.error("Error loading previous configuration", e);
    }
  }

  // Guardar configuración de Nivel
  function setLevel(lvl: string) {
    state.level = lvl;
    if (lvl === 'Alpha') {
      btnLevelAlpha?.classList.add('active');
      btnLevelBeta?.classList.remove('active');
    } else {
      btnLevelBeta?.classList.add('active');
      btnLevelAlpha?.classList.remove('active');
    }
  }

  // Cambiar cantidad de equipos (2 a 4)
  function setTeamQuantity(qty: number) {
    state.qty = qty;

    // Actualizar botones de cantidad
    qtyButtons.forEach(btn => {
      const btnQty = parseInt(btn.getAttribute('data-qty') || '0', 10);
      if (btnQty === qty) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });

    // Mostrar/ocultar tarjetas correspondientes
    teamCards.forEach((card, idx) => {
      if (card) {
        if (idx < qty) {
          card.classList.remove('hidden-card');
          card.classList.add('active-glow');
        } else {
          card.classList.add('hidden-card');
          card.classList.remove('active-glow');
        }
      }
    });

    validateFormQuietly();
  }

  // Enlazar eventos generales
  function bindEvents() {
    // Eventos Nivel
    btnLevelAlpha?.addEventListener('click', () => setLevel('Alpha'));
    btnLevelBeta?.addEventListener('click', () => setLevel('Beta'));

    // Eventos Cantidad
    qtyButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const qty = parseInt(btn.getAttribute('data-qty') || '3', 10);
        setTeamQuantity(qty);
      });
    });

    // Eventos dentro de cada Tarjeta de Equipo
    for (let i = 1; i <= 4; i++) {
      // 1. Inputs de nombre del equipo
      const nameInput = document.getElementById(`team-name-${i}`) as HTMLInputElement;
      if (nameInput) {
        nameInput.addEventListener('input', (e) => {
          const val = (e.target as HTMLInputElement).value.trim();
          state.teams[i - 1].name = val || `Equipo ${i}`;
          validateFormQuietly();
        });
      }

      // 2. Selectores de avatar (emoji)
      const avatarContainer = document.querySelector(`.avatar-options[data-team-id="${i}"]`);
      if (avatarContainer) {
        avatarContainer.querySelectorAll('.avatar-opt-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const target = e.currentTarget as HTMLButtonElement;
            let emoji = target.getAttribute('data-emoji') || '🦁';
            if (emoji === 'Ko') emoji = '🐨'; // Normalizar
            
            // Actualizar estado
            state.teams[i - 1].avatar = emoji;

            // Actualizar preview visual
            const preview = document.getElementById(`preview-avatar-${i}`);
            if (preview) {
              preview.textContent = emoji;
              // Micro-animación de rebote
              preview.style.transform = 'scale(1.3) rotate(-10deg)';
              setTimeout(() => {
                preview.style.transform = 'scale(1) rotate(0deg)';
              }, 250);
            }

            // Cambiar clase activa en los botones de este contenedor
            avatarContainer.querySelectorAll('.avatar-opt-btn').forEach(b => b.classList.remove('active'));
            target.classList.add('active');

            // Actualizar el nombre del equipo según la mascota seleccionada
            const friendlyName = emojiNames[emoji] || `Equipo ${emoji}`;
            state.teams[i - 1].name = friendlyName;
            if (nameInput) {
              nameInput.value = friendlyName;
            }

            // Sincronizar los integrantes con la nueva mascota
            const cleanName = friendlyName.replace("Equipo ", "");
            state.teams[i - 1].members = state.teams[i - 1].members.map((_, idx) => `${cleanName} ${idx + 1}`);

            // Dibujar de nuevo
            updateVisualsForTeam(i);
            validateFormQuietly();
          });
        });
      }

      // 3. Contadores de integrantes (+ y -)
      const minusBtn = document.querySelector(`.minus-btn[data-team-id="${i}"]`);
      const plusBtn = document.querySelector(`.plus-btn[data-team-id="${i}"]`);

      minusBtn?.addEventListener('click', () => {
        const team = state.teams[i - 1];
        if (team.members.length > 1) {
          team.members.pop();
          updateVisualsForTeam(i);
          validateFormQuietly();
        }
      });

      plusBtn?.addEventListener('click', () => {
        const team = state.teams[i - 1];
        if (team.members.length < 6) {
          const cleanName = team.name.replace("Equipo ", "");
          team.members.push(`${cleanName} ${team.members.length + 1}`);
          updateVisualsForTeam(i);
          validateFormQuietly();
        }
      });
    }

    // Botón Iniciar juego
    btnStart?.addEventListener('click', validateAndStart);
  }

  // Dibujar emojis e indicador de contador para un equipo
  function updateVisualsForTeam(teamId: number) {
    const team = state.teams[teamId - 1];
    const count = team.members.length;

    // Actualizar número en el contador
    const countEl = document.getElementById(`member-count-${teamId}`);
    if (countEl) countEl.textContent = count.toString();

    // Habilitar/Deshabilitar botones
    const minusBtn = document.querySelector(`.minus-btn[data-team-id="${teamId}"]`) as HTMLButtonElement;
    const plusBtn = document.querySelector(`.plus-btn[data-team-id="${teamId}"]`) as HTMLButtonElement;
    if (minusBtn) minusBtn.disabled = count <= 1;
    if (plusBtn) plusBtn.disabled = count >= 6;

    // Dibujar emojis
    const container = document.getElementById(`visual-members-${teamId}`);
    if (container) {
      container.innerHTML = '';
      for (let i = 0; i < count; i++) {
        const span = document.createElement('span');
        span.className = 'visual-member-avatar';
        span.textContent = team.avatar;
        span.style.animationDelay = `${i * 0.05}s`;
        container.appendChild(span);
      }
    }
  }

  // Actualizar todos los equipos
  function updateAllVisuals() {
    for (let i = 1; i <= 4; i++) {
      updateVisualsForTeam(i);
    }
  }

  // Validación silenciosa de errores en caliente (sin toast flotante)
  function validateFormQuietly(): boolean {
    let isValid = true;
    const names = new Set<string>();

    for (let i = 0; i < state.qty; i++) {
      const team = state.teams[i];

      // Validar integrantes
      if (team.members.length === 0) {
        isValid = false;
      }

      // Validar nombres únicos y no vacíos
      const cleanName = team.name.trim();
      if (!cleanName) {
        isValid = false;
      }
      if (names.has(cleanName)) {
        isValid = false;
      }
      names.add(cleanName);
    }

    return isValid;
  }

  // Validación final y arranque de juego
  function validateAndStart() {
    let isValid = true;
    let errorMessage = "";
    const names = new Set<string>();

    // Limpiar alertas de error previas
    errorToast?.classList.add('hidden');

    for (let i = 0; i < state.qty; i++) {
      const team = state.teams[i];
      const card = teamCards[i];
      const nameInput = document.getElementById(`team-name-${i + 1}`);

      // Validar integrantes
      if (team.members.length === 0) {
        isValid = false;
        card?.classList.add('shake-anim');
        setTimeout(() => card?.classList.remove('shake-anim'), 500);
        errorMessage = "Todos los equipos deben tener al menos un integrante.";
      }

      // Validar nombre vacío
      const cleanName = team.name.trim();
      if (!cleanName) {
        isValid = false;
        nameInput?.classList.add('shake-anim');
        setTimeout(() => nameInput?.classList.remove('shake-anim'), 500);
        errorMessage = "El nombre del equipo no puede estar vacío.";
      }

      // Validar nombres duplicados
      if (names.has(cleanName)) {
        isValid = false;
        nameInput?.classList.add('shake-anim');
        setTimeout(() => nameInput?.classList.remove('shake-anim'), 500);
        errorMessage = "Cada equipo debe tener un nombre único.";
      }
      names.add(cleanName);
    }

    if (!isValid) {
      if (errorToast) {
        errorToast.textContent = `⚠️ ${errorMessage}`;
        errorToast.classList.remove('hidden');
        
        // Sonido de error
        const audioPerder = new Audio('/sounds/perder.mp3');
        audioPerder.play().catch(err => console.log("Audio play blocked by browser:", err));
      }
      return;
    }

    // Guardar configuración limpia en LocalStorage (solo los equipos activos)
    const finalData = {
      level: state.level,
      qty: state.qty,
      teams: state.teams.slice(0, state.qty)
    };

    localStorage.setItem('serpientes_escaleras_setup', JSON.stringify(finalData));

    // Sonido de victoria al iniciar
    const audioGanar = new Audio('/sounds/Ganar.mp3');
    audioGanar.play().catch(err => console.log("Audio play blocked by browser:", err));

    // Efecto de botón antes de redirección
    btnStart?.classList.add('shake-anim');
    setTimeout(() => {
      // Redirigir al nivel seleccionado
      window.location.href = `/${state.level}`;
    }, 800);
  }

  // Arrancar inicialización al cargar el DOM
  document.addEventListener('DOMContentLoaded', init);
</script>
