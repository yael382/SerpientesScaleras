---
import Layout from '../layouts/Layout.astro';
import Ruleta from '../components/Ruleta.astro';
---

<Layout isHome={true}>
  <div class="home-container">
    <div class="home-card">
      <div class="welcome-badge">¡Hora de jugar!</div>

      <h1 class="main-title">Bienvenido al <br/> <span class="highlight">Juego de Oca</span></h1>

      <div class="intro-box">
        <p>¡Prepárate para una aventura llena de diversión y matemáticas! En este juego, cada casilla tiene un desafío matemático que debes resolver para avanzar. ¡Buena suerte!</p>
      </div>

      <div class="play-btn-container">
        <a href="/Setup" class="btn-play-now">
          ¡Comenzar a Jugar! 🎮
        </a>
      </div>
    </div>
    
    <div style="margin-top: 2rem; width: 100%; max-width: 500px; display: flex; justify-content: center;">
      <Ruleta />
    </div>
  </div>
</Layout>

<style is:global>
  .home-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-top: 1rem;
    padding: 1rem;
    animation: fadeInDown 0.6s ease-out;
  }

  .home-card {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.45), rgba(30, 41, 59, 0.25));
    backdrop-filter: blur(25px) saturate(180%);
    -webkit-backdrop-filter: blur(25px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 32px;
    padding: 3.5rem 2.5rem;
    width: 100%;
    max-width: 700px;
    box-shadow: 
      0 24px 60px rgba(0, 0, 0, 0.4), 
      inset 0 1px 1px rgba(255, 255, 255, 0.12),
      inset 0 -1px 2px rgba(255, 255, 255, 0.05),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    animation: slideInUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    position: relative;
    overflow: hidden;
  }

  /* Efecto de brillo de vidrio líquido */
  .home-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -150%;
    width: 200%;
    height: 100%;
    background: linear-gradient(
      115deg,
      transparent 35%,
      rgba(255, 255, 255, 0.15) 40%,
      rgba(255, 255, 255, 0.35) 45%,
      rgba(255, 255, 255, 0.15) 50%,
      transparent 55%
    );
    transform: skewX(-20deg);
    transition: all 1.2s cubic-bezier(0.19, 1, 0.22, 1);
    pointer-events: none;
    z-index: 1;
  }

  .home-card:hover::before {
    left: 150%;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(40px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .welcome-badge {
    position: relative;
    z-index: 2;
    background: linear-gradient(135deg, #7C3AED, #EC4899);
    color: #fff;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    animation: bounceIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(236, 72, 153, 0.4);
  }

  @keyframes bounceIn {
    0% { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  .main-title {
    position: relative;
    z-index: 2;
    color: #f8fafc;
    font-size: 2.8rem;
    margin-top: 0;
    margin-bottom: 1.5rem;
    line-height: 1.3;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .highlight {
    font-weight: 900;
    background: linear-gradient(90deg, #FFE066, #FF922B, #FF6B6B, #CC5DE8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 8px rgba(255, 146, 43, 0.45));
  }

  .intro-box {
    position: relative;
    z-index: 2;
    color: #cbd5e1;
    max-width: 600px;
    font-size: 1.15rem;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    padding: 0 1rem;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
  }

  .play-btn-container {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 0.5rem;
  }

  .btn-play-now {
    text-decoration: none;
    background: linear-gradient(135deg, #FF6B35, #FF8C42, #E11D48);
    color: #fff;
    font-size: 2.2rem;
    font-weight: 800;
    padding: 1.4rem 4.5rem;
    border-radius: 50px;
    box-shadow: 0 10px 30px rgba(255, 107, 53, 0.4), inset 0 1px 1px rgba(255, 255, 255, 0.4);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    overflow: hidden;
    display: inline-block;
  }

  .btn-play-now::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.4),
      transparent
    );
    transition: all 0.6s ease;
    transform: skewX(-25deg);
  }

  .btn-play-now:hover::before {
    left: 150%;
  }

  .btn-play-now:hover {
    transform: translateY(-8px) scale(1.05);
    box-shadow: 0 20px 45px rgba(255, 107, 53, 0.55);
  }

  .btn-play-now:active {
    transform: translateY(-2px) scale(0.98);
  }

  @media (max-width: 600px) {
    .home-container {
      padding: 0.5rem;
      margin-top: 0.5rem;
    }
    
    .home-card {
      padding: 2rem 1.2rem;
      border-radius: 24px;
      margin: 0;
    }

    .welcome-badge {
      font-size: 1rem;
      padding: 0.5rem 1.5rem;
      margin-bottom: 1.2rem;
    }

    .main-title {
      font-size: 2rem;
      margin-bottom: 1.2rem;
    }

    .intro-box {
      font-size: 1rem;
      line-height: 1.6;
      margin-bottom: 2rem;
      padding: 0 0.2rem;
    }

    .btn-play-now {
      font-size: 1.5rem;
      padding: 1.1rem 2.5rem;
      width: 100%;
      box-sizing: border-box;
      text-align: center;
    }
  }

  @media (max-width: 360px) {
    .main-title {
      font-size: 1.7rem;
    }
    .btn-play-now {
      font-size: 1.3rem;
      padding: 1rem 1.8rem;
    }
  }
</style>
