---
import Layout from '../layouts/Layout.astro';
---

<Layout isHome={true}>
  <div class="home-container">
    <div class="welcome-badge">¡Hora de jugar!</div>

    <h1 class="main-title">Bienvenido al Juego Matemático <br/> <span class="highlight">Serpientes y Escaleras</span></h1>

    <div class="intro-box">
      <p>¡Prepárate para una aventura llena de diversión y matemáticas! En este juego, cada casilla tiene un desafío matemático que debes resolver para avanzar. ¡Buena suerte!</p>
    </div>

    <div class="level-selection">
      <a href="/Alpha" class="level-card alfa-card">
        <img src="/6.jpeg" alt="Nivel Alfa" class="card-image" />
        <span class="card-title">Nivel Alfa</span>
        <span class="card-desc">Sumas y Restas (6-8 años)</span>
        <span class="card-arrow">→</span>
      </a>
      <a href="/Beta" class="level-card beta-card">
        <img src="/5.jpeg" alt="Nivel Beta" class="card-image" />
        <span class="card-title">Nivel Beta</span>
        <span class="card-desc">Multiplicación y División (9-12 años)</span>
        <span class="card-arrow">→</span>
      </a>
    </div>
  </div>
</Layout>

<style>
  .home-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-top: 1rem;
    padding: 1rem;
    animation: fadeInDown 0.6s ease-out;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .welcome-badge {
    background: linear-gradient(135deg, #C084FC, #D8B4FE);
    color: #fff;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    animation: bounceIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(192, 132, 252, 0.4);
  }

  @keyframes bounceIn {
    0% { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  .main-title {
    color: #1F1035;
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    line-height: 1.3;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.15);
  }

  .highlight {
    color: #7C3AED;
    font-weight: 700;
  }

  .intro-box {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(216, 180, 254, 0.1));
    backdrop-filter: blur(15px);
    color: #2D1B4E;
    padding: 2.5rem;
    border-radius: 32px;
    border: 3px solid rgba(124, 58, 237, 0.3);
    box-shadow: 0 12px 40px rgba(192, 132, 252, 0.25), inset 0 1px 1px rgba(255, 255, 255, 0.5);
    max-width: 700px;
    font-size: 1.15rem;
    line-height: 1.8;
    margin-bottom: 3rem;
    animation: slideInUp 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    overflow: hidden;
  }

  .intro-box::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8), transparent);
  }


  .level-selection {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .level-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    padding: 0;
    border-radius: 32px;
    min-width: 250px;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease, border-color 0.3s ease;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(255,255,255,0.92), rgba(255,255,255,0.7));
    border: 2px solid rgba(255, 255, 255, 0.75);
    box-shadow: 0 14px 40px rgba(124, 58, 237, 0.18);
    animation: bounceInUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes bounceInUp {
    0% {
      opacity: 0;
      transform: translateY(40px) scale(0.8);
    }
    50% {
      opacity: 1;
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .level-card:nth-child(1) {
    animation: bounceInUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.1s both;
  }

  .level-card:nth-child(2) {
    animation: bounceInUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
  }

  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 28px 28px 0 0;
  }

  .level-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, transparent 100%);
    pointer-events: none;
  }

  .level-card:hover {
    transform: translateY(-15px) scale(1.05);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.2);
  }

  .alfa-card {
    background: linear-gradient(135deg, #8B5CF6, #A78BFA);
    border: 2px solid rgba(139, 92, 246, 0.55);
    color: #ffffff;
  }

  .alfa-card:hover {
    transform: translateY(-6px) scale(1.02);
    border-color: #7C3AED;
    box-shadow: 0 18px 40px rgba(124, 58, 237, 0.25);
  }

  .beta-card {
    background: linear-gradient(135deg, #FBBF24, #F97316);
    border: 2px solid rgba(245, 115, 22, 0.55);
    color: #1f2937;
  }

  .beta-card:hover {
    transform: translateY(-6px) scale(1.02);
    border-color: #EA580C;
    box-shadow: 0 18px 40px rgba(245, 115, 22, 0.25);
  }

  .alfa-card .card-title,
  .beta-card .card-title {
    color: inherit;
  }

  .alfa-card .card-desc,
  .beta-card .card-desc,
  .alfa-card .card-arrow,
  .beta-card .card-arrow {
    color: inherit;
  }


  .card-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #2D1B4E;
    padding: 0 1rem;
  }

  .card-desc {
    font-size: 0.95rem;
    opacity: 0.75;
    color: #4C3B5E;
    padding: 0 1rem;
  }

  .card-arrow {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
    transition: transform 0.3s ease;
    color: #7C3AED;
    font-weight: bold;
  }

  .level-card:hover .card-arrow {
    transform: translateX(6px) scale(1.2);
  }

  @media (max-width: 600px) {
    .main-title {
      font-size: 1.8rem;
    }
    .level-card {
      min-width: unset;
      width: 100%;
    }
  }
</style>
