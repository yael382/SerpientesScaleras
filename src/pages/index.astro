---
import Layout from '../layouts/Layout.astro';
import Ruleta from '../components/Ruleta.astro';
---

<Layout isHome={true}>
  <div class="home-container">
    <div class="welcome-badge">¡Hora de jugar!</div>

    <h1 class="main-title">Bienvenido al Juego Matemático <br/> <span class="highlight">OCA</span></h1>

    <div class="intro-box">
      <p>¡Prepárate para una aventura llena de diversión y matemáticas! En este juego, cada casilla tiene un desafío matemático que debes resolver para avanzar. ¡Buena suerte!</p>
    </div>

    <div class="play-btn-container">
      <a href="/Setup" class="btn-play-now">
        ¡Comenzar a Jugar! 🎮
      </a>
    </div>
    <div style="margin-top: 3rem;">
      <Ruleta />
    </div>
  </div>
</Layout>

<style>
  .home-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-top: 1rem;
    padding: 1rem;
    animation: fadeInDown 0.6s ease-out;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .welcome-badge {
    background: linear-gradient(135deg, #C084FC, #D8B4FE);
    color: #fff;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    animation: bounceIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(192, 132, 252, 0.4);
  }

  @keyframes bounceIn {
    0% { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  .main-title {
    color: #1F1035;
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    line-height: 1.3;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.15);
  }

  .highlight {
    color: #7C3AED;
    font-weight: 700;
  }

  .intro-box {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(216, 180, 254, 0.1));
    backdrop-filter: blur(15px);
    color: #2D1B4E;
    padding: 2.5rem;
    border-radius: 32px;
    border: 3px solid rgba(124, 58, 237, 0.3);
    box-shadow: 0 12px 40px rgba(192, 132, 252, 0.25), inset 0 1px 1px rgba(255, 255, 255, 0.5);
    max-width: 700px;
    font-size: 1.15rem;
    line-height: 1.8;
    margin-bottom: 3rem;
    animation: slideInUp 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    overflow: hidden;
  }

  .intro-box::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8), transparent);
  }


  .play-btn-container {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 1.5rem;
    animation: bounceInUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes bounceInUp {
    0% {
      opacity: 0;
      transform: translateY(40px) scale(0.8);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .btn-play-now {
    text-decoration: none;
    background: linear-gradient(135deg, #FF6B35, #FF8C42, #E11D48);
    color: #fff;
    font-size: 2rem;
    font-weight: 800;
    padding: 1.4rem 4.5rem;
    border-radius: 50px;
    box-shadow: 0 10px 30px rgba(255, 107, 53, 0.4), inset 0 1px 1px rgba(255, 255, 255, 0.4);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    overflow: hidden;
    display: inline-block;
  }

  .btn-play-now::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.4),
      transparent
    );
    transition: all 0.6s ease;
    transform: skewX(-25deg);
  }

  .btn-play-now:hover::before {
    left: 150%;
  }

  .btn-play-now:hover {
    transform: translateY(-8px) scale(1.05);
    box-shadow: 0 20px 45px rgba(255, 107, 53, 0.55);
  }

  .btn-play-now:active {
    transform: translateY(-2px) scale(0.98);
  }

  @media (max-width: 600px) {
    .main-title {
      font-size: 1.8rem;
    }
    .btn-play-now {
      font-size: 1.5rem;
      padding: 1.2rem 3rem;
      width: 90%;
      text-align: center;
    }
  }
</style>
